---
---

<section class="newsletter-section py-20 relative overflow-hidden">
  <!-- Texture overlay -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.06]"
    style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%231a1a2e' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");">
  </div>

  <div class="relative z-10 max-w-2xl mx-auto px-6 text-center reveal">

    <!-- Eyebrow -->
    <p class="label-small text-dark-900/50 mb-3 tracking-widest">Stay in the Loop</p>

    <!-- Heading -->
    <h3 class="font-serif text-3xl md:text-4xl text-dark-900 font-semibold mb-3">Wedding Updates</h3>

    <!-- Divider -->
    <div class="flex items-center justify-center gap-3 mb-5">
      <div class="h-px w-12 bg-dark-900/20"></div>
      <svg class="w-3.5 h-3.5 text-dark-900/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M2.7 10.3a2.41 2.41 0 0 0 0 3.41l7.59 7.59a2.41 2.41 0 0 0 3.41 0l7.59-7.59a2.41 2.41 0 0 0 0-3.41L13.7 2.71a2.41 2.41 0 0 0-3.41 0z"/>
      </svg>
      <div class="h-px w-12 bg-dark-900/20"></div>
    </div>

    <!-- Body -->
    <p class="font-sans text-dark-800/65 text-sm leading-relaxed mb-8 max-w-md mx-auto">
      Subscribe for venue announcements, schedule confirmations, and all the details leading up to our big day.
    </p>

    <!-- Form -->
    <div x-data="newsletterForm()">
      <div x-show="subscribed" x-cloak x-transition
        class="bg-dark-900/10 rounded-2xl px-6 py-4 font-sans text-dark-900 text-sm border border-dark-900/15 font-medium">
        You're subscribed — we'll keep you posted!
      </div>
      <form x-show="!subscribed" @submit.prevent="subscribe()" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="email" x-model="email" required placeholder="your@email.com"
          class="flex-1 rounded-full px-5 py-3.5 text-dark-900 text-sm font-sans placeholder-dark-700/40 focus:outline-none focus:shadow-[0_0_0_3px_rgba(26,26,46,0.15)] transition-all bg-white/70 border border-dark-900/15 focus:border-dark-900/30"/>
        <button type="submit" :disabled="loading"
          class="bg-dark-900 hover:bg-dark-800 text-white font-sans font-medium text-sm tracking-wider uppercase px-7 py-3.5 rounded-full transition-all hover:scale-105 flex-shrink-0 disabled:opacity-50 shadow-card">
          <span x-text="loading ? 'Subscribing…' : 'Subscribe'"></span>
        </button>
      </form>
      <p x-show="error" class="text-dark-900/60 text-xs mt-3 font-sans" x-text="error"></p>
    </div>

  </div>
</section>

<style>
  .newsletter-section {
    background: linear-gradient(135deg, #e8c99a 0%, #ddb88a 40%, #e0b090 70%, #d4a8a0 100%);
  }
</style>

<script is:inline>
  function newsletterForm() {
    return {
      email:'', subscribed:false, loading:false, error:'',
      async subscribe() {
        this.loading = true; this.error = '';
        try {
          const db = window.supabase.createClient(window.__SB_URL__, window.__SB_KEY__);
          const { error } = await db.from('newsletter_subscribers').insert({ email: this.email.toLowerCase().trim() });
          if (error && !error.message.includes('duplicate') && !error.message.includes('unique')) throw new Error(error.message);
          this.subscribed = true;
        } catch(e) { this.error = e.message || 'Could not subscribe. Please try again.'; }
        finally { this.loading = false; }
      },
    };
  }
</script>
