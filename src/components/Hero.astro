---

---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background — dark gradient simulating a rich photo backdrop -->
  <div
    class="absolute inset-0 bg-[linear-gradient(160deg,#1e0b3d_0%,#2a1054_30%,#1e0b3d_70%,#140826_100%)]"
  >
  </div>

  <!-- Subtle pattern overlay -->
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: radial-gradient(circle at 20% 30%, #c69a2a 0%, transparent 50%), radial-gradient(circle at 80% 70%, #bb93d1 0%, transparent 55%);"
  >
  </div>

  <!-- Dark vignette -->
  <img
    src="/images/the-georges-hero.jpeg"
    alt="Yetunde & Babatunde"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />
  <div class="absolute inset-0 bg-dark-hero"></div>

  <!-- Replace the div above with a real photo when available:
  <img src="/images/hero.jpg" alt="Yetunde & Babatunde" class="absolute inset-0 w-full h-full object-cover object-center"/>
  <div class="absolute inset-0 bg-dark-hero"></div>
  -->

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-3xl mx-auto">
    <!-- Crest -->
    <div class="mb-6 animate-fade-in" style="animation-fill-mode:both">
      <img
        src="/images/yb-logo.svg"
        alt="Yetunde & Babatunde monogram"
        class="mx-auto h-28 md:h-36 w-auto drop-shadow-[0_0_20px_rgba(198,154,42,0.25)]"
      />
    </div>

    <!-- Pre-heading -->
    <p
      class="label-small text-white/50 mb-8 animate-fade-in"
      style="animation-delay:0.1s;animation-fill-mode:both"
    >
      Request the honour of your presence
    </p>

    <!-- Couple names -->
    <div
      class="animate-fade-in"
      style="animation-delay:0.25s;animation-fill-mode:both"
    >
      <h1
        class="font-script leading-none mb-0 text-white"
        style="font-size:clamp(4rem,12vw,8rem)"
      >
        Yetunde &amp;
      </h1>
      <h1
        class="font-script leading-none text-white"
        style="font-size:clamp(4rem,12vw,8rem)"
      >
        Babatunde
      </h1>
    </div>

    <!-- Date -->
    <div
      class="mt-8 mb-12 animate-fade-in"
      style="animation-delay:0.5s;animation-fill-mode:both"
    >
      <div class="inline-flex items-center gap-4">
        <div class="h-px w-12 gradient-bg opacity-50"></div>
        <p class="font-display text-lg text-white tracking-widest">
          Friday, 9th October 2026
        </p>
        <div class="h-px w-12 gradient-bg opacity-50"></div>
      </div>
      <p class="font-sans text-sm text-white tracking-[0.2em] uppercase mt-2">
        Elite Venue · Gravesend, Kent
      </p>
    </div>

    <!-- Countdown -->
    <div
      x-data="heroCountdown('2026-10-09T11:30:00+01:00')"
      x-init="start()"
      class="flex items-center justify-center gap-4 md:gap-8 mb-12 animate-fade-in"
      style="animation-delay:0.75s;animation-fill-mode:both"
    >
      <template x-for="(item, i) in units" :key="i">
        <div class="flex items-center gap-3 md:gap-6">
          <div class="text-center">
            <div
              class="bg-white/8 backdrop-blur-sm border border-white/10 rounded-2xl w-24 md:w-32 h-24 md:h-32 flex items-center justify-center mb-3 hover:border-gold-400/30 transition-colors"
            >
              <span
                class="font-serif text-4xl md:text-5xl font-semibold text-white"
                x-text="item.value"></span>
            </div>
            <span class="label-small text-white/35 text-xs" x-text="item.label"
            ></span>
          </div>
          <span
            class="text-white/20 font-serif text-4xl pb-8 last:hidden"
            x-show="i < 3">:</span
          >
        </div>
      </template>
    </div>

    <!-- CTAs -->
    <div
      class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in"
      style="animation-delay:1s;animation-fill-mode:both"
    >
      <a
        href="/#rsvp"
        class="inline-flex items-center justify-center font-sans font-medium text-sm tracking-wider uppercase text-white px-10 py-3.5 rounded-full transition-all duration-300 hover:scale-105"
        style="background: #c69a2a;"
      >
        RSVP
      </a>
      <a
        href="/venue"
        class="inline-flex items-center justify-center font-sans font-medium text-sm tracking-wider uppercase text-white px-10 py-3.5 rounded-full border-2 border-white/50 transition-all duration-300 hover:bg-white hover:text-dark-900"
      >
        View Details
      </a>
    </div>
  </div>

  <!-- Scroll cue -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/20 animate-bounce"
  >
    <span class="label-small text-xs">Scroll</span>
    <svg
      class="w-4 h-4"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M19 9l-7 7-7-7"></path>
    </svg>
  </div>
</section>

<script is:inline>
  function heroCountdown(targetDate) {
    return {
      units: [
        { label: "DAYS", value: "000" },
        { label: "HOURS", value: "00" },
        { label: "MINS", value: "00" },
        { label: "SECS", value: "00" },
      ],
      start() {
        this.update();
        setInterval(() => this.update(), 1000);
      },
      update() {
        const diff = new Date(targetDate).getTime() - Date.now();
        if (diff <= 0) {
          this.units.forEach((u) => (u.value = "00"));
          return;
        }
        this.units[0].value = String(Math.floor(diff / 86400000)).padStart(
          3,
          "0",
        );
        this.units[1].value = String(
          Math.floor((diff % 86400000) / 3600000),
        ).padStart(2, "0");
        this.units[2].value = String(
          Math.floor((diff % 3600000) / 60000),
        ).padStart(2, "0");
        this.units[3].value = String(
          Math.floor((diff % 60000) / 1000),
        ).padStart(2, "0");
      },
    };
  }
</script>
