---
import Icon from "./Icon.astro";

const primarySwatches = [
  {
    name: "Royal Gold",
    hex: "#c69a2a",
    role: "Primary — suits, gowns, aso-oke",
  },
  {
    name: "Lilac",
    hex: "#aa3faa",
    role: "Bride's family — gele, ipele, gowns",
  },
];

const accentSwatch = {
  name: "Deep Red",
  hex: "#B3182A",
  role: "Accent — ties, boutonnières, small accessories",
};

const groups = [
  {
    icon: "suit",
    who: "Gentlemen",
    tip: "Classic black tie or a tailored suit with a gold pocket square. A touch of red in the tie or boutonnière is warmly welcomed.",
  },
  {
    icon: "dress",
    who: "Ladies",
    tip: "Floor-length gown or cocktail dress in gold or lilac, with hints of deep red. Aso-oke and gele in our palette colours are warmly encouraged.",
  },
];
---

<section id="dress-code" class="py-24 bg-warm-100">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-14 reveal">
      <span class="section-tag">What to Wear</span>
      <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-3">
        Dress Code
      </h2>
      <p class="font-display italic text-dark-800/50 text-lg">
        Formal Elegance
      </p>
      <div class="fancy-divider mt-4">
        <Icon name="diamond" class="w-4 h-4 text-gold-500" />
      </div>
    </div>

    <div class="card p-8 md:p-10 text-center mb-10 reveal">
      <p class="font-sans text-dark-800/70 leading-relaxed max-w-2xl mx-auto">
        We kindly ask guests to dress in our wedding colours — <span
          class="gradient-text font-medium">gold and lilac</span
        >, with hints of deep red as an accent. Think elegant gowns, crisp
        suits, and aso-oke in the palette. <span
          class="gradient-text font-medium"
          >Traditional attire is warmly encouraged.</span
        >
      </p>
    </div>

    <!-- Primary palette -->
    <div class="grid grid-cols-2 gap-6 mb-8 reveal max-w-2xl mx-auto">
      {
        primarySwatches.map((s, i) => (
          <div class="group reveal" style={`transition-delay:${i * 0.08}s`}>
            <div
              class="rounded-3xl overflow-hidden aspect-square mb-3 shadow-card group-hover:shadow-card-lg transition-shadow duration-500 border border-dark-900/5"
              style={`background-color: ${s.hex};`}
            />
            <p class="font-serif text-dark-900 font-semibold text-base mb-0.5">
              {s.name}
            </p>
            <p class="font-sans text-dark-700/50 text-xs leading-relaxed">
              {s.role}
            </p>
            <p class="font-sans text-gold-500 text-xs mt-1 uppercase tracking-wider">
              {s.hex}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Accent colour (visually secondary) -->
    <div class="max-w-2xl mx-auto mb-12 reveal">
      <div
        class="flex items-center gap-5 bg-warm-50/60 border border-warm-300 rounded-2xl px-5 py-4"
      >
        <div
          class="w-14 h-14 rounded-full flex-shrink-0 shadow-sm border border-dark-900/5"
          style={`background-color: ${accentSwatch.hex};`}
        >
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <span
              class="font-sans text-[0.65rem] tracking-widest uppercase text-gold-500"
              >Accent</span
            >
            <span class="text-dark-700/30">·</span>
            <p class="font-serif text-dark-900 font-medium text-sm">
              {accentSwatch.name}
            </p>
          </div>
          <p class="font-sans text-dark-700/55 text-xs leading-relaxed">
            {accentSwatch.role}
          </p>
        </div>
        <p
          class="font-sans text-gold-500 text-[0.65rem] uppercase tracking-wider hidden sm:block"
        >
          {accentSwatch.hex}
        </p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-5 max-w-2xl mx-auto mb-16">
      {
        groups.map((g, i) => (
          <div
            class="card p-7 text-center reveal"
            style={`transition-delay:${i * 0.1}s`}
          >
            <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-4 shadow-gold">
              <Icon name={g.icon} class="w-6 h-6 text-dark-900" />
            </div>
            <h4 class="font-serif text-xl text-dark-900 font-semibold mb-2">
              {g.who}
            </h4>
            <p class="font-sans text-dark-700/65 text-sm leading-relaxed">
              {g.tip}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Family Traditional Attire -->
    <div class="mb-16 reveal">
      <div class="text-center mb-8">
        <span class="section-tag">Traditional Attire</span>
        <h3 class="font-serif text-2xl md:text-3xl text-dark-900 mb-2">
          For the Families
        </h3>
        <p
          class="font-sans text-dark-800/55 text-sm max-w-xl mx-auto mt-3 leading-relaxed"
        >
          Traditional Yoruba attire for the groom's and bride's families,
          honouring the spirit of the day.
        </p>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-5">
        <!-- Groom's Family -->
        <div class="card p-8 reveal">
          <div class="flex items-center gap-3 mb-5">
            <div
              class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0"
            >
              <Icon name="sparkle" class="w-5 h-5 text-dark-900" />
            </div>
            <div>
              <p class="label-small text-gold-500">Groom's Family</p>
              <h4 class="font-serif text-xl text-dark-900 font-semibold">
                Babatunde's Side
              </h4>
            </div>
          </div>
          <ul
            class="space-y-3 font-sans text-dark-800/70 text-sm leading-relaxed mb-4"
          >
            <li class="flex gap-3">
              <span class="text-gold-500 font-semibold flex-shrink-0"
                >Female:</span
              >
              <span
                >Gold <em class="font-display not-italic">gele</em> and <em
                  class="font-display not-italic">ipele</em
                >.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-gold-500 font-semibold flex-shrink-0"
                >Male:</span
              >
              <span>Gold <em class="font-display not-italic">fila</em>.</span>
            </li>
          </ul>
          <div class="flex items-center gap-3 border-t border-warm-300 pt-4">
            <div class="flex -space-x-2">
              <span
                class="w-6 h-6 rounded-full border-2 border-white shadow-sm"
                style="background-color:#c69a2a;"
                title="Gold"
              ></span>
            </div>
            <p class="font-sans text-xs text-dark-700/45 italic">
              Colour: Gold.
            </p>
          </div>
        </div>

        <!-- Bride's Family -->
        <div class="card p-8 reveal">
          <div class="flex items-center gap-3 mb-5">
            <div
              class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0"
            >
              <Icon name="heart" class="w-5 h-5 text-dark-900" />
            </div>
            <div>
              <p class="label-small text-gold-500">Bride's Family</p>
              <h4 class="font-serif text-xl text-dark-900 font-semibold">
                Yetunde's Side
              </h4>
            </div>
          </div>
          <ul
            class="space-y-3 font-sans text-dark-800/70 text-sm leading-relaxed mb-4"
          >
            <li class="flex gap-3">
              <span class="text-gold-500 font-semibold flex-shrink-0"
                >Female:</span
              >
              <span
                >Lilac and gold <em class="font-display not-italic">gele</em> and
                <em class="font-display not-italic">ipele</em>.</span
              >
            </li>
            <li class="flex gap-3">
              <span class="text-gold-500 font-semibold flex-shrink-0"
                >Male:</span
              >
              <span>Lilac <em class="font-display not-italic">fila</em>.</span>
            </li>
          </ul>
          <div class="flex items-center gap-3 border-t border-warm-300 pt-4">
            <div class="flex -space-x-2">
              <span
                class="w-6 h-6 rounded-full border-2 border-white shadow-sm"
                style="background-color:#aa3faa;"
                title="Lilac"
              ></span>
              <span
                class="w-6 h-6 rounded-full border-2 border-white shadow-sm"
                style="background-color:#c69a2a;"
                title="Gold"
              ></span>
            </div>
            <p class="font-sans text-xs text-dark-700/45 italic">
              Colours: Lilac &amp; gold.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Wedding Notes -->
    <div class="reveal">
      <div class="text-center mb-8">
        <span class="section-tag">Please Note</span>
        <h3 class="font-serif text-2xl md:text-3xl text-dark-900 mb-2">
          A Few Kind Reminders
        </h3>
        <div class="fancy-divider mt-4">
          <Icon name="heart" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {
          [
            {
              icon: "child",
              title: "Adults Only",
              body: "We kindly ask that this be an adults-only celebration. We hope you understand and are able to make arrangements for little ones to be cared for on the day.",
            },
            {
              icon: "sparkle",
              title: "By Invitation Only",
              body: "This celebration is strictly by invitation only. Kindly ensure that your RSVP reflects only those named on your invitation.",
            },
            {
              icon: "camera",
              title: "Social Media",
              body: "Please refrain from posting any photos or videos to social media until the couple shares the news first. We want to savour every moment together.",
            },
          ].map((n, i) => (
            <div
              class="card p-7 text-center reveal"
              style={`transition-delay:${i * 0.1}s`}
            >
              <div class="w-14 h-14 rounded-2xl bg-dark-900 flex items-center justify-center mx-auto mb-4">
                <Icon name={n.icon} class="w-6 h-6 text-gold-400" />
              </div>
              <h4 class="font-serif text-xl text-dark-900 font-semibold mb-2">
                {n.title}
              </h4>
              <p class="font-sans text-dark-700/65 text-sm leading-relaxed">
                {n.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
