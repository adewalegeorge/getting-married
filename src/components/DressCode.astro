---
import Icon from "./Icon.astro";

const primarySwatches = [
  {
    name: "Royal Gold",
    hex: "#c69a2a",
    role: "Primary: suits, gowns, aso-oke",
  },
  {
    name: "Lilac",
    hex: "#bb93d1",
    role: "Both families: gele, ipele, fila, gowns",
  },
];

const groups = [
  {
    numeral: "I",
    icon: "suit",
    who: "Gentlemen",
    tip: "Classic black tie or a tailored suit with a gold pocket square. Elegant and understated.",
  },
  {
    numeral: "II",
    icon: "dress",
    who: "Ladies",
    tip: "Floor-length or cocktail, styled in gold or lilac. Wear what makes you feel incredible.",
  },
];
---

<section id="dress-code" class="py-24 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-14 reveal">
      <span class="section-tag">What to Wear</span>
      <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-3">
        Dress Code
      </h2>
      <p class="font-display italic text-dark-800/70 text-xl md:text-2xl">
        Formal Elegance
      </p>
      <div class="fancy-divider mt-4">
        <Icon name="diamond" class="w-4 h-4 text-gold-500" />
      </div>
    </div>

    <!-- Opening quote -->
    <div class="text-center max-w-3xl mx-auto mb-16 reveal">
      <p class="font-display italic text-2xl md:text-3xl text-dark-900/85 leading-relaxed mb-5">
        "We kindly ask guests to dress in our wedding colours: <span class="gradient-text font-medium not-italic">gold &amp; lilac</span>."
      </p>
      <p class="font-sans text-base text-dark-700/75 leading-relaxed max-w-xl mx-auto">
        Think elegant gowns, crisp suits, and aso-oke in the palette. Traditional attire is warmly encouraged.
      </p>
    </div>

    <!-- Primary palette — circular swatches -->
    <div class="flex items-center justify-center gap-8 md:gap-16 mb-20 reveal">
      {
        primarySwatches.map((s, i) => (
          <div class="group text-center reveal" style={`transition-delay:${i * 0.1}s`}>
            <div
              class="relative w-28 h-28 md:w-36 md:h-36 rounded-full mx-auto mb-5 shadow-[0_15px_45px_-15px_rgba(0,0,0,0.35)] group-hover:shadow-[0_20px_55px_-12px_rgba(198,154,42,0.45)] transition-all duration-500"
              style={`background: ${s.hex};`}
            >
              <div class="absolute inset-2 rounded-full border border-white/30"></div>
              <div class="absolute -inset-2 rounded-full border border-gold-400/30 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
            <p class="font-serif text-dark-900 font-semibold text-lg md:text-xl mb-1">
              {s.name}
            </p>
            <p class="font-sans text-gold-500 text-xs uppercase tracking-[0.25em] mb-2">
              {s.hex}
            </p>
            <p class="font-sans text-dark-700/65 text-sm leading-relaxed max-w-[14rem] mx-auto">
              {s.role}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Gentlemen & Ladies — editorial chapter cards -->
    <div class="grid md:grid-cols-2 gap-5 max-w-3xl mx-auto mb-20">
      {
        groups.map((g, i) => (
          <div
            class="card p-10 text-center reveal border border-gold-400/20 hover:border-gold-400/50 transition-colors relative rounded-4xl overflow-hidden"
            style={`transition-delay:${i * 0.1}s`}
          >
            <!-- Chapter numeral -->
            <p class="font-display text-gold-500/30 text-6xl leading-none mb-2 select-none">
              {g.numeral}
            </p>
            <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mx-auto -mt-8 mb-5 shadow-gold relative z-10">
              <Icon name={g.icon} class="w-6 h-6 text-dark-900" />
            </div>
            <h4 class="font-serif text-2xl text-dark-900 font-semibold mb-3">
              {g.who}
            </h4>
            <div class="w-12 h-px bg-gold-400/40 mx-auto mb-4"></div>
            <p class="font-sans text-base text-dark-700/80 leading-relaxed">
              {g.tip}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Family Traditional Attire — featured panel -->
    <div class="mb-20 reveal relative overflow-hidden rounded-4xl p-8 md:p-14 border border-lilac-400/40 shadow-lilac-lg">
      <!-- Base gradient background -->
      <div class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(135deg, #fdf9f3 0%, #f5ece0 40%, #f0e4f5 100%);">
      </div>
      <!-- Atmospheric glow orbs -->
      <div class="absolute inset-0 pointer-events-none"
        style="background-image:
          radial-gradient(circle at 12% 15%, rgba(198,154,42,0.18) 0%, transparent 45%),
          radial-gradient(circle at 88% 85%, rgba(187,147,209,0.32) 0%, transparent 50%);">
      </div>
      <!-- Corner flourishes -->
      <span class="absolute top-5 left-5 text-gold-500/40 text-xl font-display select-none pointer-events-none">❦</span>
      <span class="absolute top-5 right-5 text-lilac-500/50 text-xl font-display select-none pointer-events-none">❦</span>
      <span class="absolute bottom-5 left-5 text-lilac-500/50 text-xl font-display select-none pointer-events-none">❦</span>
      <span class="absolute bottom-5 right-5 text-gold-500/40 text-xl font-display select-none pointer-events-none">❦</span>

      <div class="relative z-10">
        <div class="text-center mb-12">
          <span class="section-tag">Traditional Attire</span>
          <h3 class="font-serif text-3xl md:text-4xl text-dark-900 mb-3">
            For the Families
          </h3>
          <p class="font-display italic text-dark-800/75 text-lg md:text-xl">
            Both sides, united in <span class="gradient-text-theme font-medium not-italic">lilac &amp; gold</span>
          </p>
          <div class="fancy-divider mt-4">
            <Icon name="diamond" class="w-4 h-4 text-gold-500" />
          </div>
          <p class="font-sans text-base text-dark-800/75 leading-relaxed max-w-xl mx-auto mt-5">
            In Yoruba tradition, both families wear shared colours. Ours are lilac and gold, a visible sign of two families becoming one.
          </p>
        </div>

        <div class="relative grid md:grid-cols-2 gap-6">
          <!-- Center ornamental tie (desktop only) -->
          <div class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 z-20 items-center justify-center w-20 h-20 rounded-full bg-white pointer-events-none border-2"
               style="border-color: rgba(187,147,209,0.55); box-shadow: 0 0 35px rgba(187,147,209,0.45);">
            <Icon name="ring" class="w-8 h-8 text-gold-500" />
          </div>

        <!-- Groom's Family -->
        <div class="card bg-white p-8 md:p-10 reveal border border-gold-400/30 hover:border-gold-400/60 transition-colors relative overflow-hidden rounded-4xl">
          <!-- Top accent rule (lilac → gold) -->
          <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, #bb93d1, #c69a2a);"></div>
          <div class="text-center mb-6">
            <p class="font-display italic text-gold-500 text-sm tracking-widest uppercase mb-2">Groom's Family</p>
            <h4 class="font-serif text-2xl md:text-3xl text-dark-900 font-semibold mb-1">
              Babatunde's Side
            </h4>
            <div class="w-10 h-px bg-gold-400/50 mx-auto mt-3"></div>
          </div>
          <ul class="space-y-5 font-sans text-base text-dark-800/85 leading-relaxed mb-6">
            <li class="flex items-start gap-4">
              <span class="w-9 h-9 rounded-full bg-gold-500/10 border border-gold-400/40 text-gold-600 flex items-center justify-center flex-shrink-0 font-serif text-lg font-semibold select-none">♀</span>
              <div>
                <p class="label-small text-gold-500 text-xs mb-1">Female</p>
                <p>Lilac and gold <em class="font-display not-italic">gele</em> and <em class="font-display not-italic">ipele</em>.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="w-9 h-9 rounded-full bg-gold-500/10 border border-gold-400/40 text-gold-600 flex items-center justify-center flex-shrink-0 font-serif text-lg font-semibold select-none">♂</span>
              <div>
                <p class="label-small text-gold-500 text-xs mb-1">Male</p>
                <p>Lilac and gold <em class="font-display not-italic">fila</em>.</p>
              </div>
            </li>
          </ul>
          <div class="flex items-center justify-center gap-3 border-t border-warm-300 pt-5">
            <div class="flex -space-x-2">
              <span class="w-6 h-6 rounded-full border-2 border-white shadow-sm bg-lilac-400" title="Lilac"></span>
              <span class="w-6 h-6 rounded-full border-2 border-white shadow-sm bg-gold-500" title="Gold"></span>
            </div>
            <p class="font-sans text-xs text-dark-700/60 tracking-widest uppercase">Colours · Lilac &amp; Gold</p>
          </div>
        </div>

        <!-- Bride's Family -->
        <div class="card bg-white p-8 md:p-10 reveal border border-lilac-400/40 hover:border-lilac-400/70 transition-colors relative overflow-hidden rounded-4xl">
          <!-- Top accent rule (gold → lilac) -->
          <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, #c69a2a, #bb93d1);"></div>
          <div class="text-center mb-6">
            <p class="font-display italic text-lilac-500 text-sm tracking-widest uppercase mb-2">Bride's Family</p>
            <h4 class="font-serif text-2xl md:text-3xl text-dark-900 font-semibold mb-1">
              Yetunde's Side
            </h4>
            <div class="w-10 h-px bg-lilac-400 mx-auto mt-3"></div>
          </div>
          <ul class="space-y-5 font-sans text-base text-dark-800/85 leading-relaxed mb-6">
            <li class="flex items-start gap-4">
              <span class="w-9 h-9 rounded-full bg-lilac-100 border border-lilac-400/50 text-lilac-500 flex items-center justify-center flex-shrink-0 font-serif text-lg font-semibold select-none">♀</span>
              <div>
                <p class="label-small text-lilac-500 text-xs mb-1">Female</p>
                <p>Lilac and gold <em class="font-display not-italic">gele</em> and <em class="font-display not-italic">ipele</em>.</p>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <span class="w-9 h-9 rounded-full bg-lilac-100 border border-lilac-400/50 text-lilac-500 flex items-center justify-center flex-shrink-0 font-serif text-lg font-semibold select-none">♂</span>
              <div>
                <p class="label-small text-lilac-500 text-xs mb-1">Male</p>
                <p>Lilac and gold <em class="font-display not-italic">fila</em>.</p>
              </div>
            </li>
          </ul>
          <div class="flex items-center justify-center gap-3 border-t border-warm-300 pt-5">
            <div class="flex -space-x-2">
              <span class="w-6 h-6 rounded-full border-2 border-white shadow-sm bg-lilac-400" title="Lilac"></span>
              <span class="w-6 h-6 rounded-full border-2 border-white shadow-sm bg-gold-500" title="Gold"></span>
            </div>
            <p class="font-sans text-xs text-dark-700/60 tracking-widest uppercase">Colours · Lilac &amp; Gold</p>
          </div>
        </div>
      </div>
      </div>
    </div>

    <!-- Wedding Notes -->
    <div class="reveal">
      <div class="text-center mb-10">
        <span class="section-tag">Please Note</span>
        <h3 class="font-serif text-3xl md:text-4xl text-dark-900 mb-2">
          A Few Kind Reminders
        </h3>
        <p class="font-display italic text-dark-800/70 text-lg">
          With our warmest gratitude
        </p>
        <div class="fancy-divider mt-4">
          <Icon name="heart" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {
          [
            {
              numeral: "I",
              icon: "child",
              title: "Adults Only",
              body: "We kindly ask that this be an adults-only celebration. We hope you understand and are able to make arrangements for little ones to be cared for on the day.",
            },
            {
              numeral: "II",
              icon: "sparkle",
              title: "By Invitation Only",
              body: "This celebration is strictly by invitation only. Kindly ensure that your RSVP reflects only those named on your invitation.",
            },
            {
              numeral: "III",
              icon: "camera",
              title: "Social Media",
              body: "Please refrain from posting any photos or videos to social media until the couple shares the news first. We want to savour every moment together.",
            },
          ].map((n, i) => (
            <div
              class="card p-8 text-center reveal border border-gold-400/20 hover:border-gold-400/50 transition-colors relative overflow-hidden rounded-4xl"
              style={`transition-delay:${i * 0.1}s`}
            >
              <!-- Roman numeral watermark -->
              <p class="font-display text-7xl leading-none absolute top-4 right-5 select-none pointer-events-none"
                 style="color: rgb(198 154 42 / 0.09);">
                {n.numeral}
              </p>
              <div
                class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-5 shadow-lg relative z-10"
                style="background: linear-gradient(135deg, #bb93d1, #c69a2a);"
              >
                <Icon name={n.icon} class="w-6 h-6 text-white" />
              </div>
              <h4 class="font-serif text-xl text-dark-900 font-semibold mb-2 relative z-10">
                {n.title}
              </h4>
              <div class="w-10 h-px bg-gold-400/40 mx-auto mb-4"></div>
              <p class="font-sans text-base text-dark-700/80 leading-relaxed relative z-10">
                {n.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
