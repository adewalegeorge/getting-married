---
import Icon from "./Icon.astro";
---

<section id="events" class="py-24 bg-dark-900 relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(198,154,42,0.08) 0%, transparent 70%);"
  >
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-6">
    <div class="text-center mb-14 reveal">
      <span class="section-tag text-gold-400/70">Save the Date</span>
      <h2 class="font-serif text-4xl md:text-5xl text-white mb-3">
        The Celebration
      </h2>
      <p class="font-sans text-white/40 text-sm tracking-widest">
        Saturday, 10th October 2026 · Gravesend, Kent
      </p>
      <div class="fancy-divider mt-6">
        <Icon name="diamond" class="w-4 h-4 text-gold-500" />
      </div>
      <p
        class="font-sans text-white/45 text-sm leading-relaxed max-w-xl mx-auto mt-6"
      >
        Join us for our white and traditional wedding ceremonies — both held at
        the same beautiful venue, surrounded by the people we love most.
      </p>
    </div>

    <!-- Single venue card with two ceremonies -->
    <div class="mb-14">
      <div
        class="rounded-4xl bg-white/5 border border-white/10 hover:border-gold-400/30 overflow-hidden transition-all duration-400 reveal"
      >
        <!-- Venue banner -->
        <div
          class="relative aspect-[16/7] overflow-hidden event-img-placeholder"
        >
          <img
            src="/images/reception-venue.jpg"
            alt="Elite Venue, Gravesend"
            class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700"
            onload="this.style.opacity='1';this.nextElementSibling.style.display='none'"
            onerror="this.style.display='none'"
          />
          <div
            class="absolute inset-0 flex flex-col items-center justify-center gap-3"
          >
            <div class="flex gap-4">
              <div
                class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold"
              >
                <Icon name="church" class="w-5 h-5 text-white" />
              </div>
              <div
                class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold"
              >
                <Icon name="champagne" class="w-5 h-5 text-white" />
              </div>
            </div>
            <p
              class="font-sans text-xs text-white/25 tracking-widest uppercase"
            >
              One Venue · Two Ceremonies
            </p>
          </div>
          <div
            class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-dark-900/60 to-transparent pointer-events-none"
          >
          </div>
        </div>

        <!-- Venue body -->
        <div class="p-10">
          <p class="label-small text-gold-400/70 mb-2">The Venue</p>
          <h3 class="font-serif text-3xl text-white font-medium mb-2">
            Elite Venue
          </h3>
          <p class="font-sans text-white/55 mb-2">
            Dunkirk Cl, Gravesend DA12 5ND, United Kingdom
          </p>
          <p class="font-sans text-white/50 leading-relaxed mb-8">
            Both our white and traditional wedding ceremonies will take place at
            the same venue — vows, prayers, a feast, live music, and dancing
            the day and night away with family and friends.
          </p>

          <!-- Day timeline: two ceremonies -->
          <p class="label-small text-gold-400/60 mb-4">Order of the Day</p>
          <div class="space-y-4 mb-6">
            <div
              class="flex gap-5 items-center bg-white/5 border border-white/10 rounded-2xl p-5"
            >
              <div
                class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0"
              >
                <Icon name="church" class="w-5 h-5 text-white" />
              </div>
              <div class="flex-1">
                <p class="font-serif text-white text-lg font-medium mb-0.5">
                  White Wedding
                </p>
                <p class="font-sans text-white/55 text-sm">
                  Guests arrive 11:30 am
                </p>
              </div>
            </div>
            <div
              class="flex gap-5 items-center bg-white/5 border border-white/10 rounded-2xl p-5"
            >
              <div
                class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0"
              >
                <Icon name="ring" class="w-5 h-5 text-white" />
              </div>
              <div class="flex-1">
                <p class="font-serif text-white text-lg font-medium mb-0.5">
                  Traditional Wedding · Ceremony &amp; Reception
                </p>
                <p class="font-sans text-white/55 text-sm">
                  Guests arrive 2:30 pm
                </p>
              </div>
            </div>
          </div>

          <!-- Date + family footer row -->
          <div
            class="grid sm:grid-cols-2 gap-3 text-sm font-sans text-white/40 border-t border-white/8 pt-5"
          >
            <div class="flex items-center gap-2">
              <Icon
                name="calendar"
                class="w-4 h-4 text-gold-500 flex-shrink-0"
              />
              <span>Saturday, 10th October 2026</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="users" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Family &amp; Friends</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mark Your Calendars -->
    <div class="reveal">
      <div
        class="rounded-4xl border border-white/10 bg-white/3 overflow-hidden text-center px-8 py-14"
      >
        <p class="label-small text-gold-400/70 tracking-[0.3em] mb-6">
          Mark Your Calendars
        </p>

        <!-- Big date -->
        <p
          class="font-script text-white leading-none mb-2"
          style="font-size: clamp(3.5rem, 10vw, 6rem);"
        >
          10 · 10 · 2026
        </p>
        <p class="font-sans text-white/50 text-sm tracking-widest mb-8">
          Saturday
        </p>

        <!-- Venue + address -->
        <div
          class="inline-flex items-start gap-3 bg-white/5 border border-white/10 rounded-2xl px-6 py-4 mb-10 text-left max-w-md"
        >
          <Icon
            name="mappin"
            class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5"
          />
          <div>
            <p class="font-serif text-white text-base font-medium leading-snug">
              Elite Venue
            </p>
            <p class="font-sans text-white/55 text-xs leading-relaxed mt-0.5">
              Dunkirk Cl, Gravesend DA12 5ND<br />
              United Kingdom
            </p>
          </div>
        </div>

        <!-- Two ceremony times -->
        <div
          class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto mb-6"
        >
          {
            [
              {
                icon: "church",
                label: "White Wedding",
                value: "Guests arrive 11:30 am",
              },
              {
                icon: "ring",
                label: "Traditional Wedding",
                value: "Guests arrive 2:30 pm",
              },
            ].map((d) => (
              <div class="flex items-center gap-4 bg-white/5 border border-white/10 rounded-2xl px-5 py-4 text-left">
                <div class="w-11 h-11 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0">
                  <Icon name={d.icon} class="w-5 h-5 text-white" />
                </div>
                <div>
                  <p class="font-sans text-white/40 text-xs uppercase tracking-wider leading-none mb-1.5">
                    {d.label}
                  </p>
                  <p class="font-sans text-white text-sm font-medium">
                    {d.value}
                  </p>
                </div>
              </div>
            ))
          }
        </div>

        <!-- RSVP By note -->
        <div
          class="inline-flex items-center gap-3 bg-white/5 border border-white/10 rounded-full px-5 py-2.5 mb-10"
        >
          <Icon name="mail" class="w-4 h-4 text-gold-500 flex-shrink-0" />
          <p class="font-sans text-white/70 text-xs tracking-widest uppercase">
            Kindly RSVP by <span class="text-white font-medium">29th July 2026</span>
          </p>
        </div>

        <!-- CTAs -->
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a
            href="/#rsvp"
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm tracking-wider uppercase text-white px-10 py-4 rounded-full transition-all duration-300 hover:scale-105 hover:shadow-gold"
            style="background: #c69a2a;"
          >
            RSVP Now
          </a>
          <!-- Add to Calendar -->
          <a
            href="data:text/calendar;charset=utf8,BEGIN:VCALENDAR%0AVERSION:2.0%0ABEGIN:VEVENT%0ADTSTART:20261010T113000%0ADTEND:20261010T230000%0ASUMMARY:Wedding%20of%20Yetunde%20%26%20Babatunde%0ADESCRIPTION:White%20Wedding%2011%3A30am%20%7C%20Traditional%20Wedding%202%3A30pm%0ALOCATION:Elite%20Venue%2C%20Dunkirk%20Cl%2C%20Gravesend%20DA12%205ND%2C%20UK%0AEND:VEVENT%0AEND:VCALENDAR"
            download="yetunde-babatunde-wedding.ics"
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm tracking-wider uppercase text-white px-10 py-4 rounded-full border-2 border-white/20 hover:border-gold-400/50 hover:bg-white/5 transition-all duration-300"
          >
            <Icon name="calendar" class="w-4 h-4 text-gold-500" />
            Add to Calendar
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .event-img-placeholder {
    background: linear-gradient(160deg, #2a1a10 0%, #3a2a18 50%, #6a0d18 100%);
  }
</style>
