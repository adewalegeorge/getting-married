---
import Icon from "./Icon.astro";
---

<section
  id="events"
  class="py-24 relative overflow-hidden text-white"
  style="background: linear-gradient(180deg, #2a1054 0%, #1e0b3d 55%, #14082e 100%);"
>
  <!-- Decorative glow orbs -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image:
      radial-gradient(circle at 15% 15%, rgba(187,147,209,0.28) 0%, transparent 45%),
      radial-gradient(circle at 85% 85%, rgba(198,154,42,0.25) 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, rgba(61,31,112,0.35) 0%, transparent 75%);"
  >
  </div>

  <div class="relative z-10 max-w-3xl mx-auto px-6">
    <div class="text-center mb-14 reveal">
      <span class="section-tag text-gold-300">Save the Date</span>
      <h2
        class="font-serif text-4xl md:text-5xl text-white mb-3 drop-shadow-[0_0_24px_rgba(198,154,42,0.25)]"
      >
        The Celebration
      </h2>
      <p class="font-sans text-gold-400/90 text-sm tracking-widest">
        Friday, 9th October 2026 · Gravesend, Kent
      </p>
      <div class="fancy-divider mt-6">
        <Icon name="diamond" class="w-4 h-4 text-gold-400" />
      </div>
      <p
        class="font-sans text-white/85 text-base leading-relaxed max-w-xl mx-auto mt-6"
      >
        Join us for our wedding celebration in Gravesend, Kent, surrounded by
        the people we love most.
      </p>
    </div>

    <!-- Venue card -->
    <div class="mb-14">
      <div
        class="rounded-4xl bg-white border border-gold-400/40 hover:border-gold-400/70 overflow-hidden transition-all duration-400 reveal shadow-[0_20px_60px_-15px_rgba(0,0,0,0.35)]"
      >
        <!-- Venue banner -->
        <div
          class="relative aspect-[16/7] overflow-hidden event-img-placeholder"
        >
          <img
            src="/images/reception-venue.jpg"
            alt="Elite Venue, Gravesend"
            class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700"
            onload="this.style.opacity='1';this.nextElementSibling.style.display='none'"
            onerror="this.style.display='none'"
          />
          <div
            class="absolute inset-0 flex flex-col items-center justify-center gap-3"
          >
            <div
              class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold"
            >
              <Icon name="ring" class="w-5 h-5 text-white" />
            </div>
            <p
              class="font-sans text-xs text-white/70 tracking-widest uppercase"
            >
              Our Wedding Celebration
            </p>
          </div>
          <div
            class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-dark-900/60 to-transparent pointer-events-none"
          >
          </div>
        </div>

        <!-- Venue body -->
        <div class="p-10">
          <p class="label-small text-gold-500 mb-2">The Venue</p>
          <h3 class="font-serif text-3xl text-dark-900 font-semibold mb-3">
            Elite Venue
          </h3>
          <a
            href="https://www.google.com/maps/search/?api=1&query=Elite+Venue+Dunkirk+Cl+Gravesend+DA12+5ND"
            target="_blank"
            rel="noopener"
            class="inline-flex items-start gap-3 bg-warm-50 border border-gold-400/30 hover:border-gold-500 hover:bg-gold-500/5 rounded-xl px-4 py-3 mb-5 group transition-all"
          >
            <Icon name="mappin" class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" />
            <span class="flex-1">
              <span class="block font-sans text-base text-dark-900">
                Dunkirk Cl, Gravesend DA12 5ND, United Kingdom
              </span>
              <span class="block font-sans text-xs text-gold-600 font-medium tracking-wider uppercase mt-1 flex items-center gap-1 group-hover:gap-2 transition-all">
                View on Google Maps
                <Icon name="arrowright" class="w-3 h-3" />
              </span>
            </span>
          </a>
          <p class="font-sans text-base text-dark-700/80 leading-relaxed mb-8">
            Join us at Elite Venue for vows, a feast, live music, and dancing
            the day and night away with family and friends.
          </p>

          <!-- Arrival -->
          <p class="label-small text-gold-500 mb-4">Arrival</p>
          <div class="mb-6">
            <div
              class="flex gap-5 items-center bg-warm-50 border border-gold-400/25 rounded-2xl p-5 hover:border-gold-400/50 transition-colors"
            >
              <div
                class="w-12 h-12 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0"
              >
                <Icon name="ring" class="w-5 h-5 text-dark-900" />
              </div>
              <div class="flex-1">
                <p
                  class="font-serif text-dark-900 text-lg font-semibold mb-0.5"
                >
                  Wedding Celebration
                </p>
                <p class="font-sans text-dark-700/80 text-sm">
                  Guests arrive 2:30 pm
                </p>
              </div>
            </div>
          </div>

          <!-- Date + family footer row -->
          <div
            class="grid sm:grid-cols-2 gap-3 text-sm font-sans text-dark-700/80 border-t border-warm-300 pt-5"
          >
            <div class="flex items-center gap-2">
              <Icon
                name="calendar"
                class="w-4 h-4 text-gold-500 flex-shrink-0"
              />
              <span>Friday, 9th October 2026</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="users" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Family &amp; Friends</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Mark Your Calendars -->
    <div class="reveal">
      <div
        class="rounded-4xl border border-gold-400/25 bg-white/8 overflow-hidden text-center px-8 py-14 shadow-[0_0_40px_rgba(187,147,209,0.12)]"
      >
        <p class="label-small text-gold-300 tracking-[0.3em] mb-6">
          Mark Your Calendars
        </p>

        <!-- Big date -->
        <p
          class="font-script gradient-text leading-none mb-2 drop-shadow-[0_0_32px_rgba(198,154,42,0.35)]"
          style="font-size: clamp(3.5rem, 10vw, 6rem);"
        >
          09 · 10 · 2026
        </p>
        <p class="font-sans text-white/75 text-sm tracking-widest mb-8">
          Friday
        </p>

        <!-- Venue + address -->
        <div
          class="inline-flex items-start gap-3 bg-white/10 border border-gold-400/30 rounded-2xl px-6 py-4 mb-10 text-left max-w-md"
        >
          <Icon
            name="mappin"
            class="w-5 h-5 text-gold-300 flex-shrink-0 mt-0.5"
          />
          <div>
            <p class="font-serif text-white text-base font-medium leading-snug">
              Elite Venue
            </p>
            <p class="font-sans text-white/80 text-xs leading-relaxed mt-0.5">
              Dunkirk Cl, Gravesend DA12 5ND<br />
              United Kingdom
            </p>
          </div>
        </div>

        <!-- Arrival time -->
        <div class="flex justify-center mb-6">
          <div class="flex items-center gap-4 bg-white/10 border border-gold-400/25 rounded-2xl px-6 py-4 text-left hover:border-gold-400/50 transition-colors">
            <div class="w-11 h-11 rounded-2xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0">
              <Icon name="ring" class="w-5 h-5 text-white" />
            </div>
            <div>
              <p class="font-sans text-gold-300 text-xs uppercase tracking-wider leading-none mb-1.5">
                Wedding Celebration
              </p>
              <p class="font-sans text-white text-sm font-medium">
                Guests arrive 2:30 pm
              </p>
            </div>
          </div>
        </div>

        <!-- RSVP By note -->
        <div
          class="inline-flex items-center gap-3 bg-white/10 border border-gold-400/30 rounded-full px-5 py-2.5 mb-10"
        >
          <Icon name="mail" class="w-4 h-4 text-gold-300 flex-shrink-0" />
          <p class="font-sans text-white/90 text-xs tracking-widest uppercase">
            Kindly RSVP by <span class="text-gold-300 font-semibold"
              >29th July 2026</span
            >
          </p>
        </div>

        <!-- CTAs -->
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a
            href="/#rsvp"
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm tracking-wider uppercase text-white px-10 py-4 rounded-full transition-all duration-300 hover:scale-105 hover:shadow-gold-lg"
            style="background: #c69a2a;"
          >
            RSVP
          </a>
          <!-- Add to Calendar -->
          <a
            href="data:text/calendar;charset=utf8,BEGIN:VCALENDAR%0AVERSION:2.0%0ABEGIN:VEVENT%0ADTSTART:20261009T143000%0ADTEND:20261009T230000%0ASUMMARY:Wedding%20of%20Yetunde%20%26%20Babatunde%0ADESCRIPTION:Wedding%20celebration%2C%20guests%20arrive%202%3A30pm%0ALOCATION:Elite%20Venue%2C%20Dunkirk%20Cl%2C%20Gravesend%20DA12%205ND%2C%20UK%0AEND:VEVENT%0AEND:VCALENDAR"
            download="yetunde-babatunde-wedding.ics"
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm tracking-wider uppercase text-white px-10 py-4 rounded-full border-2 border-gold-400/40 hover:border-gold-400 hover:bg-white/10 transition-all duration-300"
          >
            <Icon name="calendar" class="w-4 h-4 text-gold-300" />
            Add to Calendar
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .event-img-placeholder {
    background: linear-gradient(160deg, #1e0b3d 0%, #2a1054 50%, #3d1f70 100%);
  }
</style>
