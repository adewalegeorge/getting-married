---
import Icon from './Icon.astro';
---

<section id="rsvp" class="py-24 bg-warm-50 relative overflow-hidden">
  <!-- Stationery atmosphere -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.10] mix-blend-multiply"
    style="background-image: url('/images/rsvp-stationery.jpg'); background-size: cover; background-position: center;"
    aria-hidden="true"
  ></div>
  <!-- Soft background tints (sit above the photo to warm and diffuse it) -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image:
      radial-gradient(circle at 50% 50%, rgba(253,249,243,0.55) 0%, rgba(253,249,243,0.15) 60%, transparent 80%),
      radial-gradient(circle at 90% 15%, rgba(187,147,209,0.20) 0%, transparent 45%),
      radial-gradient(circle at 10% 85%, rgba(198,154,42,0.14) 0%, transparent 45%);"
  ></div>

  <div class="relative z-10 max-w-2xl mx-auto px-6">

    <div class="text-center mb-12 reveal">
      <span class="section-tag">Join Our Celebration</span>
      <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-2">RSVP</h2>
      <p class="font-display italic text-dark-800/70 text-lg md:text-xl">
        Kindly reply by <span class="gradient-text font-medium not-italic">29th July 2026</span>
      </p>
      <div class="fancy-divider mt-4">
        <Icon name="heart" class="w-5 h-5 text-gold-500" />
      </div>
    </div>

    <div x-data="rsvpForm()" x-init="init()">

      <!-- Success (just submitted in this session) -->
      <div x-show="submitted" x-cloak x-transition class="card bg-white p-12 text-center reveal border border-gold-400/30 rounded-4xl shadow-[0_0_40px_rgba(198,154,42,0.15)]">
        <div class="w-16 h-16 rounded-full gradient-bg flex items-center justify-center mx-auto mb-6 shadow-gold-lg">
          <Icon name="heart" class="w-7 h-7 text-dark-900" />
        </div>
        <h3 class="font-serif text-3xl md:text-4xl text-dark-900 mb-2">Thank You!</h3>
        <p class="font-display italic text-dark-800/70 text-lg mb-4">With joy in our hearts</p>
        <div class="w-12 h-px bg-gold-400/60 mx-auto mb-5"></div>
        <p class="font-sans text-base text-dark-700/85 leading-relaxed max-w-md mx-auto">
          Your RSVP has been received. We can't wait to celebrate with you!
        </p>

        <!-- Gentle gift nudge -->
        <div class="mt-10 pt-8 border-t border-warm-300 max-w-md mx-auto">
          <p class="font-display italic text-dark-800/70 text-base leading-relaxed mb-5">
            For those who have kindly asked about gifts, you'll find our details here.
          </p>
          <a
            href="/gifts"
            class="inline-flex items-center justify-center gap-2 font-sans text-sm font-medium tracking-wider uppercase px-6 py-3 rounded-full border border-gold-400/50 text-gold-600 hover:bg-gold-500/10 hover:border-gold-500 transition-all"
          >
            <Icon name="gift" class="w-3.5 h-3.5" />
            View Gift Details
          </a>
        </div>
      </div>

      <!-- Previously submitted (cookie detected) -->
      <div x-show="previouslySubmitted && !submitted && !allowAnother" x-cloak x-transition
           class="card bg-white p-12 text-center reveal border border-gold-400/30 rounded-4xl shadow-[0_0_40px_rgba(187,147,209,0.15)]">
        <div class="w-16 h-16 rounded-full gradient-bg flex items-center justify-center mx-auto mb-6 shadow-gold-lg">
          <Icon name="heart" class="w-7 h-7 text-dark-900" />
        </div>
        <h3 class="font-serif text-3xl md:text-4xl text-dark-900 mb-2">You've Already RSVP'd</h3>
        <p class="font-display italic text-dark-800/70 text-lg mb-4" x-text="previousEmail ? 'Confirmed for ' + previousEmail : 'Thank you for confirming'"></p>
        <div class="w-12 h-px bg-gold-400/60 mx-auto mb-5"></div>
        <p class="font-sans text-base text-dark-700/85 leading-relaxed max-w-md mx-auto mb-8">
          Thank you for letting us know. If you need to update your response, please reach out to us directly.
        </p>
        <button
          type="button"
          @click="allowAnother = true"
          class="inline-flex items-center justify-center gap-2 font-sans text-sm font-medium tracking-wider uppercase px-6 py-3 rounded-full border border-gold-400/50 text-gold-600 hover:bg-gold-500/10 hover:border-gold-500 transition-all"
        >
          RSVP for someone else
          <Icon name="arrowright" class="w-3.5 h-3.5" />
        </button>

        <!-- Gentle gift nudge -->
        <div class="mt-10 pt-8 border-t border-warm-300 max-w-md mx-auto">
          <p class="font-display italic text-dark-800/70 text-base leading-relaxed mb-5">
            For those who have kindly asked about gifts, you'll find our details here.
          </p>
          <a
            href="/gifts"
            class="inline-flex items-center justify-center gap-2 font-sans text-sm font-medium tracking-wider uppercase px-6 py-3 rounded-full border border-gold-400/50 text-gold-600 hover:bg-gold-500/10 hover:border-gold-500 transition-all"
          >
            <Icon name="gift" class="w-3.5 h-3.5" />
            View Gift Details
          </a>
        </div>
      </div>

      <!-- Form -->
      <form x-show="!submitted && (!previouslySubmitted || allowAnother)" x-cloak @submit.prevent="submit()" novalidate class="card bg-white p-8 md:p-10 space-y-5 border border-gold-400/25 rounded-4xl">

        <!-- Honeypot: bots fill this; humans never see it. Do not remove. -->
        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;height:0;width:0;overflow:hidden;" tabindex="-1">
          <label>Website</label>
          <input type="text" name="website" x-model="form.website" tabindex="-1" autocomplete="off"/>
        </div>

        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="label-small text-dark-700/85 text-xs mb-2 block">First Name *</label>
            <input type="text" x-model="form.firstName" placeholder="Mary"
              :class="errors.firstName ? 'border-red-400 shadow-[0_0_0_3px_rgba(239,68,68,0.15)]' : 'border-warm-300 focus:border-gold-400 focus:shadow-[0_0_0_3px_rgba(198,154,42,0.15)]'"
              class="w-full border-2 rounded-xl px-4 py-3 text-dark-900 text-sm font-sans placeholder-dark-700/25 focus:outline-none transition-all bg-warm-50"/>
            <p x-show="errors.firstName" class="text-red-500 text-xs mt-1" x-text="errors.firstName"></p>
          </div>
          <div>
            <label class="label-small text-dark-700/85 text-xs mb-2 block">Last Name *</label>
            <input type="text" x-model="form.lastName" placeholder="Osagie"
              :class="errors.lastName ? 'border-red-400 shadow-[0_0_0_3px_rgba(239,68,68,0.15)]' : 'border-warm-300 focus:border-gold-400 focus:shadow-[0_0_0_3px_rgba(198,154,42,0.15)]'"
              class="w-full border-2 rounded-xl px-4 py-3 text-dark-900 text-sm font-sans placeholder-dark-700/25 focus:outline-none transition-all bg-warm-50"/>
            <p x-show="errors.lastName" class="text-red-500 text-xs mt-1" x-text="errors.lastName"></p>
          </div>
        </div>

        <div>
          <label class="label-small text-dark-700/85 text-xs mb-2 block">Email Address *</label>
          <input type="email" x-model="form.email" placeholder="your@email.com"
            :class="errors.email ? 'border-red-400 shadow-[0_0_0_3px_rgba(239,68,68,0.15)]' : 'border-warm-300 focus:border-gold-400 focus:shadow-[0_0_0_3px_rgba(198,154,42,0.15)]'"
            class="w-full border-2 rounded-xl px-4 py-3 text-dark-900 text-sm font-sans placeholder-dark-700/25 focus:outline-none transition-all bg-warm-50"/>
          <p x-show="errors.email" class="text-red-500 text-xs mt-1" x-text="errors.email"></p>
        </div>

        <div>
          <label class="label-small text-dark-700/85 text-xs mb-2 block">Phone Number</label>
          <input type="tel" x-model="form.phone" placeholder="+44 7700 900000"
            class="w-full border-2 border-warm-300 focus:border-gold-400 focus:shadow-[0_0_0_3px_rgba(198,154,42,0.15)] rounded-xl px-4 py-3 text-dark-900 text-sm font-sans placeholder-dark-700/25 focus:outline-none transition-all bg-warm-50"/>
        </div>

        <!-- Will you attend? -->
        <div>
          <label class="label-small text-dark-700/85 text-xs mb-3 block">Will you be attending? *</label>
          <div class="grid grid-cols-2 gap-3">
            {[{val:'yes',label:"Yes, I'll be there"},{val:'no',label:"Unfortunately, I can't make it"}].map(opt => (
              <label class="cursor-pointer">
                <input type="radio" x-model="form.attending" value={opt.val} class="sr-only"/>
                <div class="border-2 rounded-xl py-3.5 px-4 flex items-center gap-3 text-sm font-sans font-medium transition-all duration-200"
                  :class={`form.attending === '${opt.val}' ? 'border-gold-400 bg-gold-500/8 text-dark-900 shadow-[0_0_0_3px_rgba(198,154,42,0.15)]' : 'border-warm-300 text-dark-700/60 hover:border-gold-300'`}>
                  <div class="w-5 h-5 rounded-full border-2 flex-shrink-0 flex items-center justify-center transition-all"
                    :class={`form.attending === '${opt.val}' ? 'border-gold-500' : 'border-warm-400'`}>
                    <div class="w-2.5 h-2.5 rounded-full bg-gold-500 transition-all"
                      :class={`form.attending === '${opt.val}' ? 'scale-100' : 'scale-0'`}></div>
                  </div>
                  {opt.label}
                </div>
              </label>
            ))}
          </div>
          <p x-show="errors.attending" class="text-red-500 text-xs mt-1" x-text="errors.attending"></p>
        </div>

        <!-- Relationship -->
        <div>
          <label class="label-small text-dark-700/85 text-xs mb-2 block">Your Relationship to the Couple *</label>
          <select x-model="form.relationship"
            :class="errors.relationship ? 'border-red-400' : 'border-warm-300 focus:border-gold-400'"
            class="w-full border-2 rounded-xl px-4 py-3 text-dark-900 text-sm font-sans focus:outline-none transition-all bg-warm-50">
            <option value="" disabled selected>Select your relationship</option>
            <option value="bride_family">Bride's Family</option>
            <option value="groom_family">Groom's Family</option>
            <option value="bride_friend">Bride's Friend</option>
            <option value="groom_friend">Groom's Friend</option>
            <option value="colleague">Colleague</option>
            <option value="other">Other</option>
          </select>
          <p x-show="errors.relationship" class="text-red-500 text-xs mt-1" x-text="errors.relationship"></p>
        </div>

        <!-- Dietary -->
        <div x-show="form.attending === 'yes'" x-transition>
          <label class="label-small text-dark-700/85 text-xs mb-2 block">Dietary Requirements or Allergies</label>
          <textarea x-model="form.dietary" rows="2" placeholder="Vegetarian, nut allergy, etc."
            class="w-full border-2 border-warm-300 focus:border-gold-400 rounded-xl px-4 py-3 text-dark-900 text-sm font-sans placeholder-dark-700/30 focus:outline-none transition-all bg-warm-50 resize-none"></textarea>
        </div>

        <!-- Message -->
        <div>
          <label class="label-small text-dark-700/85 text-xs mb-2 block">A Message to the Couple</label>
          <textarea x-model="form.message" rows="3" placeholder="Share your well wishes…"
            class="w-full border-2 border-warm-300 focus:border-gold-400 rounded-xl px-4 py-3 text-dark-900 text-sm font-sans placeholder-dark-700/30 focus:outline-none transition-all bg-warm-50 resize-none"></textarea>
        </div>

        <p x-show="submitError" class="text-red-500 text-sm text-center font-sans" x-text="submitError"></p>

        <button type="submit" :disabled="loading"
          class="w-full inline-flex items-center justify-center gap-2 font-sans font-medium text-sm tracking-wider uppercase text-white py-4 rounded-xl transition-all duration-300 hover:scale-[1.02] disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:scale-100"
          style="background: #c69a2a;">
          <svg x-show="loading" class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8H4z"/>
          </svg>
          <span x-text="loading ? 'Sending…' : 'Confirm Attendance'"></span>
        </button>

      </form>
    </div>

    <!-- RSVP Contacts -->
    <div class="mt-10 reveal">
      <p class="font-sans text-base text-dark-700/75 text-center leading-relaxed mb-6">
        For further assistance or any questions regarding your RSVP, please don't hesitate to reach out to any of our contacts below.
      </p>
      <div class="grid sm:grid-cols-2 gap-4 max-w-xl mx-auto">
        {[
          { name: 'Yetunde', phone: '07506 677892' },
          { name: 'Adewale', phone: '07848 883057' },
        ].map(c => (
          <a href={`tel:${c.phone.replace(/\s/g,'')}`}
            class="card bg-white p-5 text-center group hover:scale-[1.02] transition-all duration-300 border border-gold-400/20 hover:border-gold-400/50 rounded-4xl">
            <div class="w-10 h-10 rounded-full gradient-bg flex items-center justify-center mx-auto mb-3 shadow-gold">
              <svg class="w-4 h-4 text-dark-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.38 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.6a16 16 0 0 0 5.86 5.86l.97-.97a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <p class="font-serif text-dark-900 font-semibold text-sm mb-1">{c.name}</p>
            <p class="font-sans text-gold-500 text-sm group-hover:text-gold-600 transition-colors">{c.phone}</p>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>

<script is:inline>
  function rsvpForm() {
    return {
      submitted: false,
      previouslySubmitted: false,
      previousEmail: '',
      allowAnother: false,
      loading: false,
      submitError: '',
      form: { firstName:'', lastName:'', email:'', phone:'', attending:'', relationship:'', dietary:'', message:'', website:'' },
      errors: {},
      init() {
        // Escape hatch: ?rsvp=new in the URL bypasses the cookie check
        // so a guest can submit a fresh RSVP even after a prior submission.
        const params = new URLSearchParams(window.location.search);
        if (params.get('rsvp') === 'new') {
          this.allowAnother = true;
          return;
        }
        const flag = this.getCookie('rsvp_submitted');
        if (flag) {
          this.previouslySubmitted = true;
          this.previousEmail = flag;
        }
      },
      setCookie(name, value, days = 365) {
        const exp = new Date(Date.now() + days * 86400000).toUTCString();
        document.cookie = name + '=' + encodeURIComponent(value) +
          '; expires=' + exp + '; path=/; SameSite=Lax';
      },
      getCookie(name) {
        const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
        return match ? decodeURIComponent(match[1]) : null;
      },
      validate() {
        this.errors = {};
        if (!this.form.firstName.trim()) this.errors.firstName = 'First name is required.';
        if (!this.form.lastName.trim())  this.errors.lastName  = 'Last name is required.';
        if (!this.form.email.trim() || !/\S+@\S+\.\S+/.test(this.form.email)) this.errors.email = 'A valid email is required.';
        if (!this.form.attending) this.errors.attending = 'Please select an option.';
        if (!this.form.relationship) this.errors.relationship = 'Please select your relationship.';
        return Object.keys(this.errors).length === 0;
      },
      friendlyError(error) {
        // Postgres unique-violation (duplicate email)
        if (error.code === '23505' || /duplicate key|unique constraint/i.test(error.message || '')) {
          return "It looks like you've already RSVP'd with this email. If you'd like to update your response, please reach out to us directly.";
        }
        // Postgres check-constraint violation
        if (error.code === '23514') {
          return 'One of the fields has an invalid value. Please review and try again.';
        }
        // Network / offline
        if (/fetch|network|failed to fetch/i.test(error.message || '')) {
          return "We couldn't reach our server. Please check your connection and try again.";
        }
        // Generic fallback
        return 'Something went wrong submitting your RSVP. Please try again, or contact us directly.';
      },
      async submit() {
        // Honeypot: only bots fill this. Pretend success silently.
        if (this.form.website) { this.submitted = true; return; }
        if (!this.validate()) return;
        this.loading = true; this.submitError = '';
        try {
          const db = window.supabase.createClient(window.__SB_URL__, window.__SB_KEY__);
          const { error } = await db.from('rsvps').insert({
            first_name: this.form.firstName, last_name: this.form.lastName,
            email: this.form.email.toLowerCase().trim(), phone: this.form.phone || null,
            attending: this.form.attending,
            relationship: this.form.relationship,
            dietary: this.form.dietary || null, message: this.form.message || null,
          });
          if (error) {
            this.submitError = this.friendlyError(error);
            return;
          }
          // Remember this submission for a year so they don't see the form again
          this.setCookie('rsvp_submitted', this.form.email.toLowerCase().trim());
          this.submitted = true;
        } catch(e) {
          this.submitError = this.friendlyError(e);
        }
        finally { this.loading = false; }
      },
    };
  }
</script>
