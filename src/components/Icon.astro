---
/**
 * Icon component — renders a named SVG icon.
 * All icons are 24×24 viewBox, stroke-based (stroke="currentColor").
 * Usage: <Icon name="ring" class="w-6 h-6 text-gold-500" />
 */
interface Props {
  name: string;
  class?: string;
}
const { name, class: cls = 'w-6 h-6' } = Astro.props;

const icons: Record<string, string> = {

  // ── Ceremony / wedding ────────────────────────────────────────────────────
