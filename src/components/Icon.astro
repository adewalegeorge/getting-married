  dress: `<path d="M12 3c-1.5 0-3 .5-3 2l-3 10h4l1 7h2l1-7h4L15 5c0-1.5-1.5-2-3-2z"/><circle cx="12" cy="2" r="1"/>`,

  child: `<circle cx="12" cy="7" r="3"/><path d="M6.5 21 9 12h6l2.5 9M9 16h6"/>`,

  // ── Communication ─────────────────────────────────────────────────────────
