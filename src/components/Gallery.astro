---
import Icon from './Icon.astro';

const photos = Array.from({ length: 3 }, (_, i) => ({
  id: i + 1,
  src: `/images/gallery-${i + 1}.jpg`,
  alt: `Yetunde and Babatunde - photo ${i + 1}`,
}));
---

<section id="gallery" class="py-24 bg-warm-50 relative overflow-hidden">
  <!-- Soft background tints -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image:
      radial-gradient(circle at 50% 0%, rgba(187,147,209,0.15) 0%, transparent 40%),
      radial-gradient(circle at 50% 100%, rgba(198,154,42,0.10) 0%, transparent 40%);"
  ></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6">

    <div class="text-center mb-14 reveal">
      <span class="section-tag">A Glimpse of Us</span>
      <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-3">Captured in Love</h2>
      <div class="fancy-divider"><Icon name="diamond" class="w-4 h-4 text-gold-500" /></div>
      <p class="font-sans text-base text-dark-700/80 leading-relaxed max-w-md mx-auto mt-4">
        Every photo tells a chapter. Here are a few of our favourite moments, with many more waiting for you in our full gallery.
      </p>
    </div>

    <div x-data="galleryLightbox()">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 reveal">
        {photos.map((photo, i) => (
          <div
            class="gallery-cell overflow-hidden rounded-2xl cursor-pointer group shadow-card hover:shadow-card-lg border border-gold-400/20 hover:border-gold-400/50 transition-all duration-500"
            data-src={photo.src}
            @click={`open(${i})`}
          >
            <div class="relative aspect-[3/4] overflow-hidden rounded-2xl">
              <div class="photo-placeholder w-full h-full flex flex-col items-center justify-center gap-2 group-hover:scale-105 transition-transform duration-700">
                <Icon name="camera" class="w-8 h-8 text-white/20" />
                <span class="font-sans text-xs text-white/30 tracking-wider">Photo {i + 1}</span>
              </div>
              <img src={photo.src} alt={photo.alt} loading="lazy" onload="this.style.opacity='1'" onerror="this.style.display='none'" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-700 rounded-2xl opacity-0"/>
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl flex items-center justify-center">
                <div class="w-10 h-10 rounded-full gradient-bg flex items-center justify-center shadow-gold">
                  <Icon name="camera" class="w-4 h-4 text-white" />
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Lightbox -->
      <div
        x-cloak x-show="active !== null"
        x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
        class="fixed inset-0 z-50 bg-dark-900/97 backdrop-blur-md flex items-center justify-center p-4"
        @click.self="close()" @keydown.escape.window="close()"
      >
        <button @click="prev()" class="absolute left-2 md:left-6 text-white/40 hover:text-white transition-colors p-3 rounded-full hover:bg-white/10">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <img :src="images[active] && images[active].src" :alt="images[active] && images[active].alt"
          class="max-h-[85vh] max-w-[88vw] object-contain rounded-2xl shadow-2xl"/>
        <button @click="next()" class="absolute right-2 md:right-6 text-white/40 hover:text-white transition-colors p-3 rounded-full hover:bg-white/10">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
        </button>
        <button @click="close()" class="absolute top-5 right-5 text-white/40 hover:text-white transition-colors p-2 rounded-full hover:bg-white/10">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <p class="absolute bottom-5 left-1/2 -translate-x-1/2 font-sans text-xs text-white/25 tracking-widest"
          x-text="active !== null ? (active+1) + ' / ' + images.length : ''"></p>
      </div>
    </div>

    <div class="text-center mt-10 reveal">
      <a href="/gallery" class="btn-outline">View Full Gallery</a>
    </div>

  </div>
</section>

<style>
  .photo-placeholder {
    background: linear-gradient(135deg, #1e0b3d 0%, #2a1054 50%, #3d1f70 100%);
  }
</style>

<script is:inline>
  function galleryLightbox() {
    const cells = Array.from(document.querySelectorAll('.gallery-cell'));
    const images = cells.map((el, i) => ({ src: el.dataset.src, alt: 'Photo ' + (i+1) }));
    return {
      active: null, images,
      open(i) { this.active = i; },
      close() { this.active = null; },
      prev() { this.active = (this.active - 1 + this.images.length) % this.images.length; },
      next() { this.active = (this.active + 1) % this.images.length; },
    };
  }
</script>
