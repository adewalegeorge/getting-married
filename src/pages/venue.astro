---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";

const hotels = [
  {
    tier: "Near the Venue (Gravesend & Kent)",
    options: [
      {
        name: "Premier Inn Gravesend",
        range: "From £70 / night",
        note: "Walking distance from town centre",
        icon: "building",
      },
      {
        name: "Cyclopark Hotel",
        range: "From £85 / night",
        note: "Gravesend, convenient location",
        icon: "building",
      },
      {
        name: "Travelodge Gravesend",
        range: "From £55 / night",
        note: "Budget-friendly in Gravesend",
        icon: "building",
      },
    ],
  },
  {
    tier: "Staying in London",
    options: [
      {
        name: "Premier Inn London Bridge",
        range: "From £100 / night",
        note: "~30 min train to Gravesend",
        icon: "building",
      },
      {
        name: "Holiday Inn Canary Wharf",
        range: "From £120 / night",
        note: "Easy connections to Gravesend",
        icon: "building",
      },
      {
        name: "The Shard Area Hotels",
        range: "From £150 / night",
        note: "London Bridge station nearby",
        icon: "star",
      },
    ],
  },
];

const travel = [
  {
    icon: "plane",
    title: "From the Airport",
    body: "Heathrow and Gatwick are the nearest major airports. From central London, Gravesend is approximately 30 minutes by train from London Bridge or St Pancras.",
  },
  {
    icon: "train",
    title: "By Train",
    body: "Regular train services run from London Bridge and London Cannon Street to Gravesend. Journey time is around 30–35 minutes.",
  },
  {
    icon: "car",
    title: "By Car / Taxi",
    body: "Gravesend is accessible via the A2/M2. Ubers and local taxis are available. Pre-booking your return journey after the reception is strongly recommended.",
  },
];
---

<Layout title="Venue & Travel - Yetunde & Babatunde">
  <PageHero
    title="Venue & Travel"
    subtitle="Saturday, 10th October 2026 · Gravesend, Kent"
    breadcrumb="Venue & Travel"
    image="/images/the-georges-hero.jpeg"
  />

  <!-- Venues -->
  <section class="py-24 bg-warm-50 relative overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image:
        radial-gradient(circle at 85% 15%, rgba(187,147,209,0.18) 0%, transparent 45%),
        radial-gradient(circle at 15% 85%, rgba(198,154,42,0.14) 0%, transparent 45%);"
    ></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <span class="section-tag">Where We Celebrate</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-2">Our Venue</h2>
        <p class="font-display italic text-dark-800/70 text-lg md:text-xl">
          One venue · Two ceremonies
        </p>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="max-w-2xl mx-auto reveal">
        <div class="card bg-white p-10 md:p-12 border border-gold-400/25 hover:border-gold-400/50 transition-colors relative overflow-hidden rounded-4xl">
          <!-- Top accent rule -->
          <div class="absolute top-0 left-0 right-0 h-1 gradient-bg"></div>
          <div class="flex gap-3 mb-6">
            <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center shadow-gold">
              <Icon name="ring" class="w-6 h-6 text-dark-900" />
            </div>
            <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center shadow-gold">
              <Icon name="champagne" class="w-6 h-6 text-dark-900" />
            </div>
          </div>
          <p class="font-display italic text-gold-500 text-sm tracking-widest uppercase mb-2">
            White &amp; Traditional Wedding
          </p>
          <h3 class="font-serif text-3xl text-dark-900 font-semibold mb-1">
            Elite Venue
          </h3>
          <p class="font-sans text-base text-dark-700/80 mb-5">
            Dunkirk Cl, Gravesend DA12 5ND, UK
          </p>
          <div class="w-12 h-px bg-gold-400/40 mb-5"></div>
          <div class="space-y-3 text-base font-sans text-dark-700/80 mb-5">
            <div class="flex items-center gap-3">
              <Icon name="clock" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>White Wedding: guests arrive 11:30 am</span>
            </div>
            <div class="flex items-center gap-3">
              <Icon name="clock" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Traditional Wedding: guests arrive 2:30 pm</span>
            </div>
            <div class="flex items-center gap-3">
              <Icon name="mappin" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Gravesend, Kent, United Kingdom</span>
            </div>
            <div class="flex items-center gap-3">
              <Icon name="calendar" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Saturday, 10th October 2026</span>
            </div>
          </div>
          <p class="font-sans text-sm text-dark-700/60 italic border-t border-warm-300 pt-5">
            Both ceremonies take place at the same venue. Full directions and
            parking information will be shared with confirmed guests.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Accommodation -->
  <section class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <span class="section-tag">Where to Stay</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-2">
          Accommodation
        </h2>
        <p class="font-display italic text-dark-800/70 text-lg md:text-xl">
          A restful stay for our guests
        </p>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        {
          hotels.map((group, gi) => (
            <div class="reveal" style={`transition-delay:${gi * 0.1}s`}>
              <p class="font-display italic text-gold-500 text-sm tracking-widest uppercase mb-2">{group.tier}</p>
              <div class="w-12 h-px bg-gold-400/40 mb-5"></div>
              <div class="space-y-4">
                {group.options.map((h) => (
                  <div class="card p-5 flex items-center justify-between gap-4 border border-gold-400/20 hover:border-gold-400/50 transition-colors rounded-4xl">
                    <div class="flex items-center gap-4">
                      <div class="w-10 h-10 rounded-xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0">
                        <Icon name={h.icon} class="w-4 h-4 text-dark-900" />
                      </div>
                      <div>
                        <p class="font-serif text-dark-900 font-semibold text-base">
                          {h.name}
                        </p>
                        <p class="font-sans text-dark-700/70 text-sm">
                          {h.note}
                        </p>
                      </div>
                    </div>
                    <span class="gradient-text font-sans font-semibold text-sm whitespace-nowrap">
                      {h.range}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <p class="text-center font-sans italic text-dark-700/70 text-base mt-10 reveal max-w-xl mx-auto">
        October in London is popular, so we recommend booking accommodation early.
      </p>
    </div>
  </section>

  <!-- Getting here -->
  <section class="py-24 bg-warm-100 relative overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image:
        radial-gradient(circle at 15% 20%, rgba(187,147,209,0.18) 0%, transparent 45%),
        radial-gradient(circle at 85% 80%, rgba(198,154,42,0.14) 0%, transparent 45%);"
    ></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <span class="section-tag">How to Get Here</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-2">
          Getting There
        </h2>
        <p class="font-display italic text-dark-800/70 text-lg md:text-xl">
          Three ways to join us in Gravesend
        </p>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {
          travel.map((t, i) => (
            <div
              class="card p-8 text-center reveal border border-gold-400/20 hover:border-gold-400/50 transition-colors rounded-4xl"
              style={`transition-delay:${i * 0.1}s`}
            >
              <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-5 shadow-gold">
                <Icon name={t.icon} class="w-6 h-6 text-dark-900" />
              </div>
              <h4 class="font-serif text-xl text-dark-900 font-semibold mb-3">
                {t.title}
              </h4>
              <div class="w-10 h-px bg-gold-400/40 mx-auto mb-4"></div>
              <p class="font-sans text-base text-dark-700/80 leading-relaxed">
                {t.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
