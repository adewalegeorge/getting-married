---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";

const hotels = [
  {
    tier: "Near the Venue (Gravesend & Kent)",
    options: [
      {
        name: "Premier Inn Gravesend",
        range: "From £70 / night",
        note: "Walking distance from town centre",
        icon: "building",
      },
      {
        name: "Cyclopark Hotel",
        range: "From £85 / night",
        note: "Gravesend, convenient location",
        icon: "building",
      },
      {
        name: "Travelodge Gravesend",
        range: "From £55 / night",
        note: "Budget-friendly in Gravesend",
        icon: "building",
      },
    ],
  },
  {
    tier: "Staying in London",
    options: [
      {
        name: "Premier Inn London Bridge",
        range: "From £100 / night",
        note: "~30 min train to Gravesend",
        icon: "building",
      },
      {
        name: "Holiday Inn Canary Wharf",
        range: "From £120 / night",
        note: "Easy connections to Gravesend",
        icon: "building",
      },
      {
        name: "The Shard Area Hotels",
        range: "From £150 / night",
        note: "London Bridge station nearby",
        icon: "star",
      },
    ],
  },
];

const travel = [
  {
    icon: "plane",
    title: "From the Airport",
    body: "Heathrow and Gatwick are the nearest major airports. From central London, Gravesend is approximately 30 minutes by train from London Bridge or St Pancras.",
  },
  {
    icon: "train",
    title: "By Train",
    body: "Regular train services run from London Bridge and London Cannon Street to Gravesend. Journey time is around 30–35 minutes.",
  },
  {
    icon: "car",
    title: "By Car / Taxi",
    body: "Gravesend is accessible via the A2/M2. Ubers and local taxis are available. Pre-booking your return journey after the reception is strongly recommended.",
  },
];
---

<Layout title="Venue & Travel — Yetunde & Babatunde">
  <PageHero
    title="Venue & Travel"
    subtitle="Saturday, 10th October 2026 · Gravesend, Kent"
    breadcrumb="Venue & Travel"
    image="/images/the-georges-hero.jpeg"
  />

  <!-- Venues -->
  <section class="py-24 bg-warm-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <span class="section-tag">Where We Celebrate</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900">Our Venue</h2>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="max-w-2xl mx-auto reveal">
        <div class="card p-10">
          <div class="flex gap-3 mb-6">
            <div
              class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center shadow-gold"
            >
              <Icon name="ring" class="w-6 h-6 text-dark-900" />
            </div>
            <div
              class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center shadow-gold"
            >
              <Icon name="champagne" class="w-6 h-6 text-dark-900" />
            </div>
          </div>
          <span class="section-tag">White &amp; Traditional Wedding</span>
          <h3 class="font-serif text-2xl text-dark-900 font-semibold mb-1">
            Elite Venue
          </h3>
          <p class="font-sans text-dark-700/55 text-sm mb-5">
            Dunkirk Cl, Gravesend DA12 5ND, UK
          </p>
          <div class="space-y-2 text-sm font-sans text-dark-700/55 mb-4">
            <div class="flex items-center gap-2">
              <Icon name="clock" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>White Wedding — guests arrive 11:30 am</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="clock" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Traditional Wedding — guests arrive 2:30 pm</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon name="mappin" class="w-4 h-4 text-gold-500 flex-shrink-0" />
              <span>Gravesend, Kent, United Kingdom</span>
            </div>
            <div class="flex items-center gap-2">
              <Icon
                name="calendar"
                class="w-4 h-4 text-gold-500 flex-shrink-0"
              />
              <span>Saturday, 10th October 2026</span>
            </div>
          </div>
          <p
            class="font-sans text-xs text-dark-700/35 italic border-t border-warm-300 pt-4"
          >
            Both ceremonies take place at the same venue. Full directions and
            parking information will be shared with confirmed guests.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Accommodation -->
  <section class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <span class="section-tag">Where to Stay</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900">
          Accommodation
        </h2>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="grid md:grid-cols-2 gap-10">
        {
          hotels.map((group, gi) => (
            <div class="reveal" style={`transition-delay:${gi * 0.1}s`}>
              <p class="label-small text-gold-500 mb-5">{group.tier}</p>
              <div class="space-y-4">
                {group.options.map((h) => (
                  <div class="card p-5 flex items-center justify-between gap-4">
                    <div class="flex items-center gap-4">
                      <div class="w-9 h-9 rounded-xl gradient-bg flex items-center justify-center shadow-gold flex-shrink-0">
                        <Icon name={h.icon} class="w-4 h-4 text-dark-900" />
                      </div>
                      <div>
                        <p class="font-serif text-dark-900 font-semibold">
                          {h.name}
                        </p>
                        <p class="font-sans text-dark-700/50 text-xs">
                          {h.note}
                        </p>
                      </div>
                    </div>
                    <span class="gradient-text font-sans font-medium text-sm whitespace-nowrap">
                      {h.range}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>
      <p class="text-center font-sans text-dark-700/40 text-sm mt-10 reveal">
        October in London is popular — we recommend booking accommodation early.
      </p>
    </div>
  </section>

  <!-- Getting here -->
  <section class="py-24 bg-warm-100">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14 reveal">
        <span class="section-tag">How to Get Here</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900">
          Getting There
        </h2>
        <div class="fancy-divider mt-4">
          <Icon name="diamond" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {
          travel.map((t, i) => (
            <div
              class="card p-8 text-center reveal"
              style={`transition-delay:${i * 0.1}s`}
            >
              <div class="w-14 h-14 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-5 shadow-gold">
                <Icon name={t.icon} class="w-6 h-6 text-dark-900" />
              </div>
              <h4 class="font-serif text-xl text-dark-900 font-semibold mb-3">
                {t.title}
              </h4>
              <p class="font-sans text-dark-700/60 text-sm leading-relaxed">
                {t.body}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
