---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
---

<Layout title="Gift Registry — Yetunde & Babatunde">
  <PageHero title="Gift Registry" subtitle="Your presence is our greatest gift" breadcrumb="Gift Registry" image="/images/registry.jpg" />

  <!-- Intro -->
  <section class="py-20 bg-warm-50">
    <div class="max-w-2xl mx-auto px-6 text-center reveal">
      <h2 class="font-script text-5xl gradient-text mb-4">A Note From Us</h2>
      <p class="font-display italic text-xl text-dark-800/65 leading-relaxed mb-4">
        "Your presence at our wedding is truly the greatest gift of all."
      </p>
      <p class="font-sans text-dark-700/60 text-sm leading-relaxed">
        For those who have kindly asked, we have put together a small selection of ideas.
        Any contribution — big or small — is deeply appreciated as we begin our life together.
      </p>
    </div>
  </section>

  <!-- Gift cards -->
  <section class="pb-24 bg-warm-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-3 gap-6">

        <!-- Honeymoon -->
        <div class="card p-8 text-center flex flex-col reveal">
          <div class="w-16 h-16 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-5 shadow-gold">
            <Icon name="globe" class="w-7 h-7 text-dark-900" />
          </div>
          <span class="section-tag">Honeymoon Fund</span>
          <h3 class="font-serif text-2xl text-dark-900 font-semibold mb-4">Adventures Together</h3>
          <p class="font-sans text-dark-700/60 text-sm leading-relaxed flex-1 mb-6">
            Help us create unforgettable memories on our honeymoon. Any contribution towards our travel fund would mean the world.
          </p>
          <a href="/#rsvp" class="btn-outline">Contribute</a>
        </div>

        <!-- Bank transfer — preferred -->
        <div class="card p-8 text-center flex flex-col relative overflow-hidden reveal">
          <div class="absolute top-0 left-0 right-0 h-1 gradient-bg"></div>
          <div class="absolute top-3 right-4">
            <span class="gradient-bg text-white font-sans text-xs font-semibold tracking-wider uppercase px-3 py-1 rounded-full">Preferred</span>
          </div>
          <div class="w-16 h-16 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-5 shadow-gold mt-4">
            <Icon name="banknote" class="w-7 h-7 text-dark-900" />
          </div>
          <span class="section-tag">Monetary Gift</span>
          <h3 class="font-serif text-2xl text-dark-900 font-semibold mb-4">Bank Transfer</h3>
          <p class="font-sans text-dark-700/60 text-sm leading-relaxed flex-1 mb-5">
            A direct bank transfer is the easiest way to contribute. Please use your name as the reference so we know who to thank.
          </p>
          <div class="bg-warm-200 rounded-2xl p-4 text-left space-y-2 mb-4">
            {[
              { l:'Account Name', v:'Coming Soon' },
              { l:'Sort Code',    v:'XX - XX - XX' },
              { l:'Account No.', v:'XXXXXXXX' },
            ].map(r => (
              <div class="flex justify-between text-xs font-sans">
                <span class="text-dark-700/40">{r.l}</span>
                <span class="text-dark-900 font-medium">{r.v}</span>
              </div>
            ))}
          </div>
          <p class="font-sans text-dark-700/35 text-xs italic">Bank details confirmed closer to the date.</p>
        </div>

        <!-- Registry -->
        <div class="card p-8 text-center flex flex-col reveal">
          <div class="w-16 h-16 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-5 shadow-gold">
            <Icon name="home" class="w-7 h-7 text-dark-900" />
          </div>
          <span class="section-tag">Home Registry</span>
          <h3 class="font-serif text-2xl text-dark-900 font-semibold mb-4">Our New Home</h3>
          <p class="font-sans text-dark-700/60 text-sm leading-relaxed flex-1 mb-6">
            We are setting up our first home together. Practical gifts for the kitchen and living spaces are always welcome.
          </p>
          <a href="https://www.johnlewis.com/gift-list" target="_blank" rel="noopener" class="btn-outline">John Lewis</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Closing -->
  <section class="py-16 relative overflow-hidden thank-you-section">
    <div class="absolute inset-0 pointer-events-none opacity-[0.06]"
      style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%231a1a2e' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");">
    </div>
    <div class="relative z-10 max-w-2xl mx-auto px-6 text-center reveal">
      <h3 class="font-serif text-3xl text-dark-900 font-semibold mb-3">Thank You</h3>
      <p class="font-sans text-dark-800/70 text-sm leading-relaxed mb-8">
        Whether you travel far, send your love from home, or simply share in our joy —
        your kindness means everything to us both.
      </p>

      <!-- Bible verse -->
      <div class="border-t border-dark-900/20 pt-7 mb-8">
        <p class="font-display italic text-dark-900/80 text-xl leading-relaxed mb-3">
          "Every good gift and every perfect gift is from above, coming down from the Father of lights."
        </p>
        <p class="label-small text-dark-900/50 tracking-widest">— James 1:17</p>
      </div>

      <a href="/#rsvp"
        class="inline-flex items-center justify-center font-sans font-semibold text-sm tracking-wider uppercase text-white px-10 py-3.5 rounded-full transition-all duration-300 hover:scale-105"
        style="background: #B3182A;">
        RSVP Now
      </a>
    </div>
  </section>

  <style>
    .thank-you-section {
      background: linear-gradient(135deg, #e8c99a 0%, #ddb88a 40%, #c69a2a 100%);
    }
  </style>
</Layout>
