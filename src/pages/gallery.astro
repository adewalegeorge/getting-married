---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";

const photos = Array.from({ length: 6 }, (_, i) => ({
  id: i + 1,
  src: `/images/gallery-${i + 1}.jpg`,
  alt: `Yetunde and Babatunde - photo ${i + 1}`,
}));
---

<Layout title="Gallery - Yetunde & Babatunde">
  <PageHero
    title="Gallery"
    subtitle="Moments we treasure together"
    breadcrumb="Gallery"
    image="/images/gallery-hero.jpg"
  />

  <section class="py-24 bg-warm-50 relative overflow-hidden">
    <div
      class="absolute inset-0 pointer-events-none"
      style="background-image:
        radial-gradient(circle at 10% 10%, rgba(187,147,209,0.15) 0%, transparent 40%),
        radial-gradient(circle at 90% 90%, rgba(198,154,42,0.12) 0%, transparent 40%);"
    ></div>
    <div class="relative z-10 max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 reveal">
        <span class="section-tag">A Glimpse of Us</span>
        <h2 class="font-serif text-4xl md:text-5xl text-dark-900 mb-2">Our Story in Photos</h2>
        <p class="font-display italic text-dark-800/70 text-lg md:text-xl">
          Moments we treasure together
        </p>
        <div class="fancy-divider mt-4">
          <Icon name="heart" class="w-4 h-4 text-gold-500" />
        </div>
      </div>
      <div x-data="fullGallery()" class="max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 reveal justify-items-center">
          {
            photos.map((photo, i) => (
              <div
                class="gallery-cell w-full overflow-hidden rounded-2xl cursor-pointer group shadow-card hover:shadow-card-lg transition-all duration-500 border border-gold-400/20 hover:border-gold-400/50"
                data-src={photo.src}
                @click={`open(${i})`}
              >
                <div class="relative aspect-[3/4] overflow-hidden rounded-2xl">
                  <div class="photo-placeholder w-full h-full flex flex-col items-center justify-center gap-2 group-hover:scale-105 transition-transform duration-700">
                    <svg
                      class="h-8 w-8 text-white/20"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    <span class="font-sans text-xs text-white/30 tracking-wider">
                      Photo {i + 1}
                    </span>
                  </div>
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-700 rounded-2xl opacity-0"
                    onload="this.style.opacity='1'"
                    onerror="this.style.display='none'"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-dark-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl flex items-center justify-center">
                    <div class="w-10 h-10 rounded-full gradient-bg flex items-center justify-center shadow-gold">
                      <svg
                        class="w-4 h-4 text-white"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zm-3-3l3 3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Lightbox — teleported to <body> so position:fixed escapes any
             parent that has transform/filter/contain (which would otherwise
             scope it to that ancestor and let later sections render over it). -->
        <template x-teleport="body">
          <div
            x-cloak
            x-show="active !== null"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            class="fixed inset-0 z-[999] bg-dark-900/97 backdrop-blur-md flex items-center justify-center p-4"
            @click.self="close()"
            @keydown.escape.window="close()"
          >
            <button
              @click="prev()"
              aria-label="Previous photo"
              class="absolute left-2 md:left-6 z-10 w-11 h-11 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-dark-900/55 backdrop-blur-sm border border-white/20 text-white/85 hover:text-white hover:bg-dark-900/75 hover:border-white/40 transition-colors text-2xl leading-none"
              >&#8249;</button
            >
            <img
              :src="images[active] && images[active].src"
              :alt="images[active] && images[active].alt"
              class="max-h-[85vh] max-w-[88vw] object-contain rounded-2xl shadow-2xl"
            />
            <button
              @click="next()"
              aria-label="Next photo"
              class="absolute right-2 md:right-6 z-10 w-11 h-11 md:w-12 md:h-12 flex items-center justify-center rounded-full bg-dark-900/55 backdrop-blur-sm border border-white/20 text-white/85 hover:text-white hover:bg-dark-900/75 hover:border-white/40 transition-colors text-2xl leading-none"
              >&#8250;</button
            >
            <button
              @click="close()"
              aria-label="Close gallery"
              class="absolute top-5 right-5 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-dark-900/55 backdrop-blur-sm border border-white/20 text-white/85 hover:text-white hover:bg-dark-900/75 hover:border-white/40 transition-colors"
            >
              <svg
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M6 18L18 6M6 6l12 12"></path></svg
              >
            </button>
            <p
              class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 px-3 py-1 rounded-full bg-dark-900/55 backdrop-blur-sm border border-white/15 font-sans text-xs text-white/85 tracking-widest"
              x-text="active !== null ? (active+1) + ' / ' + images.length : ''"
            >
            </p>
          </div>
        </template>
      </div>

      <!-- Upload CTA -->
      <div
        class="mt-16 reveal"
        x-data="{
          active: false,
          init() {
            const target = new Date('2026-10-09T15:30:00+01:00').getTime();
            const check = () => { this.active = Date.now() >= target; };
            check();
            if (!this.active) setInterval(check, 60000);
          }
        }"
        x-init="init()"
      >
        <div class="relative rounded-4xl overflow-hidden bg-white border border-gold-400/30 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.18)]">
          <div class="absolute top-0 left-0 right-0 h-1 gradient-bg"></div>
          <div
            class="absolute inset-0 pointer-events-none"
            style="background-image:
              radial-gradient(circle at 15% 20%, rgba(187,147,209,0.18) 0%, transparent 55%),
              radial-gradient(circle at 85% 80%, rgba(198,154,42,0.15) 0%, transparent 55%);"
          ></div>

          <!-- Active (from 3:30pm on 9 Oct 2026) -->
          <div x-show="active" x-cloak class="relative grid md:grid-cols-5 gap-0">
            <!-- QR polaroid -->
            <div class="md:col-span-2 flex items-center justify-center p-10 md:p-12">
              <a
                href="https://photos.app.goo.gl/8PeNWqxGnHWHnV5j9"
                target="_blank"
                rel="noopener"
                class="block group"
                aria-label="Scan to open the shared photo album"
              >
                <div class="relative bg-white p-4 pb-10 rounded-2xl border border-gold-400/30 shadow-[0_15px_40px_-12px_rgba(30,11,61,0.25)] transition-all duration-500 group-hover:-rotate-2 group-hover:scale-[1.03] group-hover:shadow-[0_20px_50px_-12px_rgba(30,11,61,0.35)]">
                  <img
                    src="/qr-photos.png"
                    alt="QR code linking to the shared photo album"
                    width="200"
                    height="200"
                    class="block w-40 h-40 sm:w-48 sm:h-48"
                  />
                  <p class="absolute bottom-6 left-0 right-0 text-center font-display italic text-gold-600 text-sm tracking-wider">
                    scan to share
                  </p>
                </div>
              </a>
            </div>

            <!-- Copy + CTA -->
            <div class="md:col-span-3 p-10 md:p-14 flex flex-col justify-center text-center md:text-left border-t md:border-t-0 md:border-l border-gold-400/20">
              <p class="font-display italic text-gold-500 text-sm tracking-widest uppercase mb-3">
                A Kind Invitation
              </p>
              <h3 class="font-script text-dark-900 leading-[0.95] mb-5" style="font-size: clamp(2.75rem, 6vw, 4rem);">
                Be our photographers
              </h3>
              <p class="font-sans text-base text-dark-700/80 leading-relaxed mb-8 max-w-sm mx-auto md:mx-0">
                Every angle, every smile, every quiet moment. Drop them straight into our shared album.
              </p>
              <div class="flex justify-center md:justify-start">
                <a
                  href="https://photos.app.goo.gl/8PeNWqxGnHWHnV5j9"
                  target="_blank"
                  rel="noopener"
                  class="btn-primary inline-flex items-center gap-2"
                >
                  <Icon name="camera" class="w-4 h-4" />
                  Add to Our Album
                </a>
              </div>
            </div>
          </div>

          <!-- Locked (before 3:30pm on 9 Oct 2026) -->
          <div x-show="!active" x-cloak class="relative grid md:grid-cols-5 gap-0">
            <!-- Lock tile (replaces QR polaroid) -->
            <div class="md:col-span-2 flex items-center justify-center p-10 md:p-12">
              <div class="relative bg-warm-50 p-4 pb-10 rounded-2xl border border-gold-400/30 shadow-[0_15px_40px_-12px_rgba(30,11,61,0.18)]">
                <div class="w-40 h-40 sm:w-48 sm:h-48 flex flex-col items-center justify-center gap-4 bg-white rounded-xl border border-gold-400/20">
                  <div class="w-14 h-14 rounded-2xl bg-warm-100 border border-gold-400/30 flex items-center justify-center">
                    <Icon name="lock" class="w-6 h-6 text-gold-500" />
                  </div>
                  <p class="font-display italic text-gold-600 text-sm tracking-wider text-center px-4">
                    9 Oct · 3:30 pm
                  </p>
                </div>
                <p class="absolute bottom-6 left-0 right-0 text-center font-display italic text-dark-700/60 text-sm tracking-wider">
                  opens on the day
                </p>
              </div>
            </div>

            <!-- Locked copy -->
            <div class="md:col-span-3 p-10 md:p-14 flex flex-col justify-center text-center md:text-left border-t md:border-t-0 md:border-l border-gold-400/20">
              <p class="font-display italic text-gold-500 text-sm tracking-widest uppercase mb-3">
                Coming on the Day
              </p>
              <h3 class="font-script text-dark-900 leading-[0.95] mb-5" style="font-size: clamp(2.75rem, 6vw, 4rem);">
                The album opens soon
              </h3>
              <p class="font-sans text-base text-dark-700/80 leading-relaxed max-w-sm mx-auto md:mx-0">
                Photo sharing goes live on Friday 9 October at 3:30 pm, once the day is well underway. Pop back then to add your favourite moments.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .photo-placeholder {
    background: linear-gradient(135deg, #1e0b3d 0%, #2a1054 50%, #3d1f70 100%);
  }
</style>

<!-- fullGallery() is registered globally in Layout.astro (as an alias to
     galleryLightbox) so the factory is available before Alpine.initTree fires
     under SPA navigation. -->

