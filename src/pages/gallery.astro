---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";

const photos = Array.from({ length: 3 }, (_, i) => ({
  id: i + 1,
  src: `/images/gallery-${i + 1}.jpg`,
  alt: `Yetunde and Babatunde - photo ${i + 1}`,
}));
---

<Layout title="Gallery — Yetunde & Babatunde">
  <PageHero
    title="Gallery"
    subtitle="Moments we treasure together"
    breadcrumb="Gallery"
    image="/images/gallery-hero-couple.jpg"
  />

  <section class="py-24 bg-warm-50">
    <div class="max-w-6xl mx-auto px-6">
      <div x-data="fullGallery()">
        <div class="columns-2 md:columns-3 lg:columns-4 gap-3 reveal">
          {
            photos.map((photo, i) => (
              <div
                class="gallery-cell break-inside-avoid mb-3 overflow-hidden rounded-2xl cursor-pointer group shadow-card hover:shadow-card-lg transition-shadow duration-500"
                data-src={photo.src}
                @click={`open(${i})`}
              >
                <div class="relative aspect-[3/4] overflow-hidden rounded-2xl">
                  <div class="photo-placeholder w-full h-full flex flex-col items-center justify-center gap-2 group-hover:scale-105 transition-transform duration-700">
                    <svg
                      class="h-8 w-8 text-white/20"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1"
                        d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    <span class="font-sans text-xs text-white/30 tracking-wider">
                      Photo {i + 1}
                    </span>
                  </div>
                  <img
                    src={photo.src}
                    alt={photo.alt}
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-all duration-700 rounded-2xl opacity-0"
                    onload="this.style.opacity='1'"
                    onerror="this.style.display='none'"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-dark-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-2xl flex items-center justify-center">
                    <div class="w-10 h-10 rounded-full gradient-bg flex items-center justify-center shadow-gold">
                      <svg
                        class="w-4 h-4 text-white"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zm-3-3l3 3" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Lightbox -->
        <div
          x-cloak
          x-show="active !== null"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          class="fixed inset-0 z-50 bg-dark-900/97 backdrop-blur-md flex items-center justify-center p-4"
          @click.self="close()"
          @keydown.escape.window="close()"
        >
          <button
            @click="prev()"
            class="absolute left-4 text-white/40 hover:text-white transition-colors p-4 text-4xl"
            >&#8249;</button
          >
          <img
            :src="images[active] && images[active].src"
            :alt="images[active] && images[active].alt"
            class="max-h-[85vh] max-w-[88vw] object-contain rounded-2xl shadow-2xl"
          />
          <button
            @click="next()"
            class="absolute right-4 text-white/40 hover:text-white transition-colors p-4 text-4xl"
            >&#8250;</button
          >
          <button
            @click="close()"
            class="absolute top-6 right-6 text-white/40 hover:text-white transition-colors"
          >
            <svg
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M6 18L18 6M6 6l12 12"></path></svg
            >
          </button>
          <p
            class="absolute bottom-5 left-1/2 -translate-x-1/2 font-sans text-xs text-white/25 tracking-widest"
            x-text="active !== null ? (active+1) + ' / ' + images.length : ''"
          >
          </p>
        </div>
      </div>

      <!-- Upload CTA -->
      <div class="mt-16 card p-12 text-center reveal">
        <div
          class="w-16 h-16 rounded-2xl gradient-bg flex items-center justify-center mx-auto mb-5 shadow-gold"
        >
          <svg
            class="w-7 h-7 text-dark-900"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path
              d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"
            ></path><circle cx="12" cy="13" r="3"></circle></svg
          >
        </div>
        <h3 class="font-serif text-2xl text-dark-900 font-semibold mb-3">
          Share Your Photos
        </h3>
        <p
          class="font-sans text-dark-700/60 text-sm max-w-md mx-auto mb-6 leading-relaxed"
        >
          Captured a special moment? We'd love to see it! Send your photos and
          we'll add them to the gallery.
        </p>
        <a
          href="mailto:hello@example.com?subject=Wedding Photos"
          class="btn-primary">Send Us Your Photos</a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .photo-placeholder {
    background: linear-gradient(135deg, #2a1a10 0%, #3a2a18 50%, #6a0d18 100%);
  }
</style>

<script is:inline>
  function fullGallery() {
    const cells = Array.from(document.querySelectorAll(".gallery-cell"));
    const images = cells.map((el, i) => ({
      src: el.dataset.src,
      alt: "Photo " + (i + 1),
    }));
    return {
      active: null,
      images,
      open(i) {
        this.active = i;
      },
      close() {
        this.active = null;
      },
      prev() {
        this.active =
          (this.active - 1 + this.images.length) % this.images.length;
      },
      next() {
        this.active = (this.active + 1) % this.images.length;
      },
    };
  }
</script>
