---
interface Props {
  title?: string;
  description?: string;
}
const {
  title       = "Yetunde & Babatunde — 10.10.2026",
  description = "Join us as we celebrate the union of Yetunde & Babatunde on 10th October 2026.",
} = Astro.props;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL  ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const navLinks = [
  { href: '/gallery', label: 'Gallery' },
  { href: '/venue',   label: 'Venue & Travel' },
  { href: '/gifts',   label: 'Gift Registry' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content={description}/>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
</head>
<body>

<!-- ░░ NAVBAR ░░ -->
<nav
  id="navbar"
  x-data="{ open: false, scrolled: false }"
  x-init="window.addEventListener('scroll', () => scrolled = window.scrollY > 60)"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-400"
  :class="scrolled ? 'bg-white/95 backdrop-blur-md shadow-sm py-3' : 'bg-transparent py-5'"
>
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-script text-xl leading-none transition-colors"
       :class="scrolled ? 'text-dark-900' : 'text-white'">
      Yetunde &amp; Babatunde
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-sans text-sm font-medium tracking-wide transition-colors"
          :class="scrolled ? 'text-dark-800 hover:text-gold-500' : 'text-white/90 hover:text-white'"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/#rsvp"
        class="btn-primary text-xs px-6 py-2.5"
      >
        RSVP Now
      </a>
    </div>

    <!-- Mobile burger -->
    <button
      class="md:hidden p-1 focus:outline-none"
      :class="scrolled ? 'text-dark-900' : 'text-white'"
      @click="open = !open"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path x-show="!open" d="M4 6h16M4 12h16M4 18h16"/>
        <path x-show="open"  d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    x-show="open" x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="md:hidden bg-white/97 backdrop-blur-md border-t border-warm-300 px-6 py-4 shadow-lg"
  >
    <ul class="space-y-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} @click="open=false"
             class="block font-sans text-sm font-medium text-dark-800 hover:text-gold-500 py-2 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/#rsvp" @click="open=false" class="btn-primary w-full text-xs py-3">RSVP Now</a>
      </li>
    </ul>
  </div>
</nav>

<!-- ░░ CONTENT ░░ -->
<main id="top">
  <slot />
</main>

<!-- ░░ FOOTER ░░ -->
<footer class="bg-dark-900 text-white">
  <!-- Top gradient bar -->
  <div class="h-1 gradient-bg w-full"></div>

  <div class="max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

    <!-- Brand -->
    <div class="sm:col-span-2 lg:col-span-1">
      <p class="font-script text-5xl gradient-text mb-2">Yetunde &amp; Babatunde</p>
      <p class="label-small text-white/30 mb-5">10 · 10 · 2026 · London</p>
      <p class="font-sans text-sm text-white/45 leading-relaxed mb-6">
        Two hearts united in love, celebrated with family and friends across two continents.
      </p>
      <!-- Social -->
      <div class="flex gap-3">
        {[
          { name:'Instagram', d:'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
        ].map(s => (
          <a href="#" aria-label={s.name} class="w-9 h-9 rounded-full border border-white/15 hover:border-gold-400/60 flex items-center justify-center text-white/30 hover:text-gold-400 transition-all">
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor"><path d={s.d}/></svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Quick Links -->
    <div>
      <p class="label-small text-gold-400 mb-5">Navigation</p>
      <ul class="space-y-3">
        {[
          ['/', 'Home'],
          ['/#our-story', 'Our Story'],
          ['/#events', 'Events'],
          ['/#dress-code', 'Dress Code'],
          ['/venue', 'Venue & Travel'],
          ['/gallery', 'Gallery'],
          ['/gifts', 'Gift Registry'],
          ['/#rsvp', 'RSVP'],
        ].map(([href, label]) => (
          <li>
            <a href={href} class="font-sans text-sm text-white/45 hover:text-gold-400 transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-3 h-px bg-gold-400 transition-all duration-300 overflow-hidden"></span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Wedding Details -->
    <div>
      <p class="label-small text-gold-400 mb-5">The Wedding</p>
      <div class="space-y-4">
        {[
          { icon: 'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z', label: 'Date',       value: 'Saturday\n10th October 2026' },
          { icon: 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0zM12 10m-3 0a3 3 0 1 0 6 0 3 3 0 1 0-6 0',         label: 'Location',   value: 'Gravesend, Kent\nUnited Kingdom' },
          { icon: 'M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM22 7l-10 7L2 7',       label: 'RSVP By',    value: '29th July 2026' },
          { icon: 'M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 0 0 2-2V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z', label: 'Dress Code', value: 'Formal — Gold & Lilac' },
        ].map(item => (
          <div class="flex gap-3">
            <svg class="w-4 h-4 text-gold-500/60 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
            <div>
              <p class="label-small text-white/25 text-xs mb-0.5">{item.label}</p>
              <p class="font-sans text-sm text-white/55 leading-snug whitespace-pre-line">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Contact + Newsletter -->
    <div>
      <p class="label-small text-gold-400 mb-5">Stay Updated</p>
      <p class="font-sans text-sm text-white/45 leading-relaxed mb-5">
        Get venue updates, schedule confirmations, and all the latest news from us.
      </p>

      <div x-data="footerSub()">
        <p x-show="done" x-cloak class="font-sans text-sm text-gold-400 py-2">✓ You're subscribed!</p>
        <form x-show="!done" @submit.prevent="sub()" class="space-y-2">
          <input type="email" x-model="email" required
            class="w-full bg-white/8 border border-white/12 focus:border-gold-400/50 rounded-xl px-4 py-2.5 text-white text-sm font-sans placeholder-white/25 focus:outline-none transition-colors"
            placeholder="your@email.com"/>
          <button type="submit" :disabled="loading" class="w-full btn-primary text-xs py-2.5 rounded-xl">
            <span x-text="loading ? 'Subscribing…' : 'Subscribe'"></span>
          </button>
        </form>
      </div>

      <div class="mt-7 pt-6 border-t border-white/8">
        <p class="label-small text-white/20 mb-2">Enquiries</p>
        <a href="mailto:hello@example.com" class="font-sans text-sm text-gold-400/70 hover:text-gold-400 transition-colors">
          hello@example.com
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/8">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/25 font-sans">
      <p>© {new Date().getFullYear()} Yetunde &amp; Babatunde</p>
      <p>Made with ♡ in London</p>
    </div>
  </div>
</footer>

<!-- Back to top -->
<button
  x-data="{ show: false }"
  x-init="window.addEventListener('scroll', () => show = window.scrollY > 500)"
  x-show="show" x-cloak x-transition
  @click="window.scrollTo({ top:0, behavior:'smooth' })"
  class="fixed bottom-7 right-7 z-40 w-14 h-14 rounded-full bg-gold-500 text-white shadow-gold flex items-center justify-center hover:scale-110 hover:bg-gold-600 transition-all duration-300"
  aria-label="Back to top"
>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path d="M5 15l7-7 7 7"/>
  </svg>
</button>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script define:vars={{ supabaseUrl, supabaseKey }}>
  window.__SB_URL__ = supabaseUrl;
  window.__SB_KEY__ = supabaseKey;
</script>

<!-- Scroll reveal + smooth anchor scroll -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Scroll reveal
    const io = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.1 }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    // Smooth scroll for all anchor links, accounting for fixed navbar
    document.addEventListener('click', e => {
      const a = e.target.closest('a[href]');
      if (!a) return;
      const href = a.getAttribute('href');
      // Match same-page hashes (#section) or root-page hashes (/#section)
      const match = href.match(/^(?:\/)?#(.+)$/);
      if (!match) return;
      const target = document.getElementById(match[1]);
      if (!target) return;
      e.preventDefault();
      const navHeight = document.getElementById('navbar')?.offsetHeight ?? 80;
      const top = target.getBoundingClientRect().top + window.scrollY - navHeight - 16;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  });
</script>

<script is:inline>
  function footerSub() {
    return {
      email:'', done:false, loading:false,
      async sub() {
        this.loading = true;
        try {
          const db = window.supabase.createClient(window.__SB_URL__, window.__SB_KEY__);
          await db.from('newsletter_subscribers').insert({ email: this.email.toLowerCase().trim() });
          this.done = true;
        } catch(e) { /* silent */ }
        finally { this.loading = false; }
      }
    };
  }
</script>

</body>
</html>
