---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  standalone?: boolean;
  noindex?: boolean;
}
const {
  title       = "Yetunde & Babatunde - 09.10.2026",
  description = "Join us as we celebrate the union of Yetunde & Babatunde on 9th October 2026.",
  standalone  = false,
  noindex     = false,
} = Astro.props;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL  ?? '';
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';

const siteUrl = Astro.site ?? new URL('https://yb-wedding.pages.dev');
const ogImage = new URL('/images/the-georges-hero.jpeg', siteUrl).href;
const canonical = new URL(Astro.url.pathname, siteUrl).href;

const navLinks = [
  { href: '/gallery', label: 'Gallery' },
  { href: '/venue',   label: 'Venue & Travel' },
  { href: '/gifts',   label: 'Gift Registry' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content={description}/>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  {!noindex && <link rel="canonical" href={canonical}/>}
  {noindex && <meta name="robots" content="noindex,nofollow"/>}

  <!-- Open Graph / Facebook / WhatsApp / iMessage -->
  <meta property="og:type" content="website"/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:image" content={ogImage}/>
  <meta property="og:image:alt" content="Yetunde & Babatunde"/>
  <meta property="og:url" content={canonical}/>
  <meta property="og:site_name" content="Yetunde & Babatunde"/>
  <meta property="og:locale" content="en_GB"/>

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={title}/>
  <meta name="twitter:description" content={description}/>
  <meta name="twitter:image" content={ogImage}/>
  <meta name="twitter:image:alt" content="Yetunde & Babatunde"/>

  <!-- SPA-style cross-fade navigation -->
  <ClientRouter />
</head>
<body>

{!standalone && (
<!-- ░░ NAVBAR ░░ -->
<nav
  id="navbar"
  transition:persist
  x-data="{ open: false, scrolled: false }"
  x-init="scrolled = window.scrollY > 60; window.addEventListener('scroll', () => scrolled = window.scrollY > 60)"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-400"
  :class="scrolled ? 'bg-white/95 backdrop-blur-md shadow-sm py-3' : 'bg-transparent py-5'"
>
  <div class="max-w-6xl mx-auto px-6 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Yetunde & Babatunde - Home">
      <img
        src="/images/yb-logo.svg"
        alt=""
        class="h-10 md:h-11 w-auto text-gold-500 transition-all duration-300 group-hover:scale-105"
        :class="scrolled ? 'drop-shadow-none' : 'drop-shadow-[0_0_12px_rgba(198,154,42,0.35)]'"
      />
      <span
        class="font-script text-xl leading-none transition-colors hidden sm:inline"
        :class="scrolled ? 'text-dark-900' : 'text-white'"
      >
        Yetunde &amp; Babatunde
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-sans text-sm font-medium tracking-wide transition-colors"
          :class="scrolled ? 'text-dark-800 hover:text-gold-500' : 'text-white/90 hover:text-white'"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/#rsvp"
        class="font-sans text-sm font-medium tracking-wide transition-colors"
        :class="scrolled ? 'text-dark-800 hover:text-gold-500' : 'text-white/90 hover:text-white'"
      >
        RSVP
      </a>
    </div>

    <!-- Mobile burger -->
    <button
      class="md:hidden p-1 focus:outline-none"
      :class="scrolled ? 'text-dark-900' : 'text-white'"
      @click="open = !open"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path x-show="!open" d="M4 6h16M4 12h16M4 18h16"/>
        <path x-show="open"  d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    x-show="open" x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    class="md:hidden bg-white/97 backdrop-blur-md border-t border-warm-300 px-6 py-4 shadow-lg"
  >
    <ul class="space-y-4">
      {navLinks.map(link => (
        <li>
          <a href={link.href} @click="open=false"
             class="block font-sans text-sm font-medium text-dark-800 hover:text-gold-500 py-2 transition-colors">
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/#rsvp" @click="open=false" class="btn-primary w-full text-xs py-3">RSVP</a>
      </li>
    </ul>
  </div>
</nav>
)}

<!-- ░░ CONTENT ░░ -->
<main id="top">
  <slot />
</main>

<!-- ░░ FOOTER ░░ -->
<footer class="relative overflow-hidden text-white"
        style="background: linear-gradient(180deg, #2a1054 0%, #1e0b3d 55%, #14082e 100%);">
  <!-- Top gold bar -->
  <div class="h-1 gradient-bg w-full"></div>

  <!-- Decorative glow orbs -->
  <div class="absolute inset-0 pointer-events-none"
       style="background-image:
         radial-gradient(circle at 12% 15%, rgba(187,147,209,0.28) 0%, transparent 45%),
         radial-gradient(circle at 88% 85%, rgba(198,154,42,0.22) 0%, transparent 50%),
         radial-gradient(circle at 50% 50%, rgba(61,31,112,0.4) 0%, transparent 70%);">
  </div>

  <div class={`relative z-10 max-w-6xl mx-auto px-6 py-16 ${standalone ? 'flex justify-center' : 'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12'}`}>

    <!-- Brand -->
    <div class={standalone ? 'max-w-2xl text-center' : 'sm:col-span-2 lg:col-span-2'}>
      <div class={`flex items-start gap-5 mb-5 ${standalone ? 'justify-center' : ''}`}>
        <img
          src="/images/yb-logo.svg"
          alt="Yetunde & Babatunde"
          class="h-36 w-auto flex-shrink-0 drop-shadow-[0_0_20px_rgba(198,154,42,0.55)]"
        />
        <div class="min-w-0">
          <p class="font-script text-[30px] md:text-5xl gradient-text mb-3 leading-tight">Yetunde &amp; Babatunde</p>
          <p class="label-small text-gold-400/80">09 · 10 · 2026 · Gravesend, Kent</p>
        </div>
      </div>
      <p class={`font-sans text-base md:text-lg text-white/85 leading-relaxed ${standalone ? 'mx-auto' : ''} max-w-xl`}>
        Two hearts united in love, celebrated with family and friends across two continents.
      </p>
    </div>

    {!standalone && (
    <>
    <!-- Quick Links -->
    <div>
      <p class="label-small text-gold-400 mb-5">Navigation</p>
      <ul class="space-y-3">
        {[
          ['/', 'Home'],
          ['/#events', 'Wedding Details'],
          ['/venue', 'Venue & Travel'],
          ['/gallery', 'Photo Gallery'],
          ['/gifts', 'Gift Registry'],
          ['/#rsvp', 'RSVP'],
        ].map(([href, label]) => (
          <li>
            <a href={href} class="font-sans text-sm text-white/80 hover:text-gold-300 transition-colors flex items-center gap-2 group">
              <span class="w-0 group-hover:w-3 h-px bg-gold-400 transition-all duration-300 overflow-hidden"></span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Wedding Details -->
    <div>
      <p class="label-small text-gold-400 mb-5">The Wedding</p>
      <div class="space-y-4">
        {[
          { icon: 'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z', label: 'Date',       value: 'Friday\n9th October 2026' },
          { icon: 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0zM12 10m-3 0a3 3 0 1 0 6 0 3 3 0 1 0-6 0',         label: 'Location',   value: 'Gravesend, Kent\nUnited Kingdom' },
          { icon: 'M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2zM22 7l-10 7L2 7',       label: 'RSVP By',    value: '29th July 2026' },
        ].map(item => (
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-gold-500/15 border border-gold-400/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-gold-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon}></svg>
            </div>
            <div>
              <p class="label-small text-gold-400/80 text-xs mb-0.5">{item.label}</p>
              <p class="font-sans text-sm text-white/85 leading-snug whitespace-pre-line">{item.value}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    </>
    )}

  </div>

  <!-- Bottom bar -->
  <div class="relative z-10 border-t border-gold-400/20 bg-black/20">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/65 font-sans">
      <p>© {new Date().getFullYear()} Yetunde &amp; Babatunde</p>
      <p>Made by <a href="http://kinetechlab.uk" target="_blank" rel="noopener" class="text-gold-300 hover:text-gold-200 transition-colors">Kinetech Lab</a></p>
    </div>
  </div>
</footer>

{!standalone && (
<!-- Back to top -->
<button
  transition:persist
  x-data="{ show: false }"
  x-init="show = window.scrollY > 500; window.addEventListener('scroll', () => show = window.scrollY > 500)"
  x-show="show" x-cloak x-transition
  @click="window.scrollTo({ top:0, behavior:'smooth' })"
  class="fixed bottom-7 right-7 z-40 w-14 h-14 rounded-full bg-gold-500 text-white shadow-gold flex items-center justify-center hover:scale-110 hover:bg-gold-600 transition-all duration-300"
  aria-label="Back to top"
>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
    <path d="M5 15l7-7 7 7"/>
  </svg>
</button>
)}

<!-- Scripts -->
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script define:vars={{ supabaseUrl, supabaseKey }}>
  window.__SB_URL__ = supabaseUrl;
  window.__SB_KEY__ = supabaseKey;
</script>
<!-- Bundle Supabase locally via Astro instead of CDN (more reliable) -->
<script>
  import { createClient } from '@supabase/supabase-js';
  // Expose with the same API the inline scripts expect: window.supabase.createClient(...)
  (window as any).supabase = { createClient };
</script>

<!-- Scroll reveal + smooth anchor scroll + Alpine re-init across view transitions -->
<script is:inline>
  // Reveal elements already in view synchronously (kills above-the-fold flash on
  // initial load and on every view-transition swap), and observe the rest.
  function initReveal() {
    const io = new IntersectionObserver(
      (entries, observer) => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -8% 0px' }
    );
    const vh = window.innerHeight;
    document.querySelectorAll('.reveal:not(.visible)').forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < vh && r.bottom > 0) {
        el.classList.add('visible');
      } else {
        io.observe(el);
      }
    });
  }

  // Re-scan Alpine on the new body content after a view-transition swap.
  function reinitAlpine() {
    const Alpine = window.Alpine;
    if (Alpine && typeof Alpine.initTree === 'function') {
      Alpine.initTree(document.body);
    }
  }

  // Smooth-scroll for in-page anchors. Registered once — survives view transitions.
  let smoothScrollBound = false;
  function bindSmoothScroll() {
    if (smoothScrollBound) return;
    smoothScrollBound = true;
    document.addEventListener('click', e => {
      const t = e.target;
      const a = t && t instanceof Element ? t.closest('a[href]') : null;
      if (!a) return;
      const href = a.getAttribute('href') || '';
      const match = href.match(/^(?:\/)?#(.+)$/);
      if (!match) return;
      const target = document.getElementById(match[1]);
      if (!target) return;
      e.preventDefault();
      const navHeight = document.getElementById('navbar')?.offsetHeight ?? 80;
      const top = target.getBoundingClientRect().top + window.scrollY - navHeight - 16;
      window.scrollTo({ top, behavior: 'smooth' });
    });
  }

  // astro:page-load fires on initial load AND after every soft navigation.
  document.addEventListener('astro:page-load', () => {
    initReveal();
    reinitAlpine();
    bindSmoothScroll();
  });
</script>

</body>
</html>
